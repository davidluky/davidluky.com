---
interface Props {
  id?: string;
  label: string;
  heading: string;
}

const { id, label, heading } = Astro.props;
---

<section id={id} class="border-t border-border">
  <div class="mx-auto max-w-[1280px] px-12 py-[88px] max-md:px-6 max-md:py-16">
    <div class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
      {label}
    </div>
    <h2 class="mb-5 max-w-[620px] text-[30px] font-light leading-snug tracking-tight">
      {heading}
    </h2>
    <slot />
  </div>
</section>
