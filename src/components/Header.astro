---
interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;

const navLinks = [
  { href: "/projects", label: "Projects", i18n: "nav_projects" },
  { href: "/gaming", label: "Gaming", i18n: "nav_gaming" },
  { href: "/about", label: "About", i18n: "nav_about" },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-bg/90 backdrop-blur-xl transition-all duration-300"
>
  <div class="mx-auto flex h-[60px] max-w-[1280px] items-center justify-between px-12 max-md:h-[52px] max-md:px-6">
    <!-- Brand: "DAVID LUKY" morphs to "DL" on scroll -->
    <a href="/" class="brand-mark group no-underline">
      <span class="brand-text"><span class="brand-keep">D</span><span class="brand-mid">avid</span><span class="brand-gap"></span><span class="brand-keep">L</span><span class="brand-mid">uky</span></span>
    </a>

    <!-- Desktop navigation -->
    <nav class="flex items-center gap-8 max-md:hidden">
      {navLinks.map(({ href, label, i18n }) => (
        <a
          href={href}
          data-i18n={i18n}
          class:list={[
            "text-sm no-underline transition-colors",
            currentPath === href ? "text-text" : "text-text-2 hover:text-text",
          ]}
        >
          {label}
        </a>
      ))}
      <button
        id="lang-switch"
        aria-label="Switch language"
        class="text-[12px] font-semibold text-text-3 hover:text-text transition-colors cursor-pointer"
      >
        <span id="lang-label" data-lang-label>EN</span>
      </button>
      <a
        href="https://play.davidluky.com"
        target="_blank"
        rel="noopener noreferrer"
        data-i18n="nav_play"
        class="rounded-md bg-accent px-4 py-2 text-[13px] font-medium text-bg no-underline transition-opacity hover:opacity-90"
      >
        Play The Room
      </a>
    </nav>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-btn"
      class="mobile-menu-btn"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg id="menu-icon" class="w-5 h-5 text-text-2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-5 h-5 text-text-2 pointer-events-none" style="display:none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <nav
    id="mobile-menu"
    class="mobile-menu-closed border-t border-border/20 bg-bg/95 backdrop-blur-xl"
  >
    <div class="mx-auto max-w-[1280px] px-6 py-5 flex flex-col gap-4">
      {navLinks.map(({ href, label, i18n }) => (
        <a
          href={href}
          data-i18n={i18n}
          class:list={[
            "text-[15px] no-underline transition-colors py-1",
            currentPath === href ? "text-text" : "text-text-2 hover:text-text",
          ]}
        >
          {label}
        </a>
      ))}
      <button
        id="lang-switch-mobile"
        aria-label="Switch language"
        class="text-[13px] font-semibold text-text-3 hover:text-text transition-colors cursor-pointer py-1 text-left"
      >
        <span id="lang-label-mobile" data-lang-label>EN</span>
      </button>
      <a
        href="https://play.davidluky.com"
        target="_blank"
        rel="noopener noreferrer"
        data-i18n="nav_play"
        class="mt-1 w-fit rounded-md bg-accent px-4 py-2 text-[13px] font-medium text-bg no-underline transition-opacity hover:opacity-90"
      >
        Play The Room
      </a>
    </div>
  </nav>
</header>

<script>
  import { syncLanguageControls, toggleLanguage } from '../i18n/shared';

  document.addEventListener('DOMContentLoaded', function() {
    var header = document.getElementById('site-header');
    var menuBtn = document.getElementById('mobile-menu-btn');
    var mobileMenu = document.getElementById('mobile-menu');
    var menuIcon = document.getElementById('menu-icon');
    var closeIcon = document.getElementById('close-icon');

    // Scroll morph — higher threshold on mobile so the full name is visible longer
    if (header) {
      var headerEl = header;
      var scrolled = false;
      var threshold = window.innerWidth < 768 ? 150 : 60;
      window.addEventListener('resize', function() {
        threshold = window.innerWidth < 768 ? 150 : 60;
      }, { passive: true });
      function onScroll() {
        var past = window.scrollY > threshold;
        if (past !== scrolled) {
          scrolled = past;
          headerEl.classList.toggle('header-scrolled', past);
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    syncLanguageControls();
    function switchLang() {
      toggleLanguage();
      location.reload();
    }
    var langSwitch = document.getElementById('lang-switch');
    var langSwitchMobile = document.getElementById('lang-switch-mobile');
    if (langSwitch) langSwitch.addEventListener('click', switchLang);
    if (langSwitchMobile) langSwitchMobile.addEventListener('click', switchLang);

    // Mobile menu toggle
    if (menuBtn && mobileMenu) {
      var menuButton = menuBtn;
      var menuPanel = mobileMenu;
      menuButton.addEventListener('click', function() {
        var open = menuPanel.classList.contains('mobile-menu-open');
        menuPanel.classList.toggle('mobile-menu-closed', open);
        menuPanel.classList.toggle('mobile-menu-open', !open);
        menuButton.setAttribute('aria-expanded', String(!open));
        if (menuIcon) menuIcon.style.display = open ? 'block' : 'none';
        if (closeIcon) closeIcon.style.display = open ? 'none' : 'block';
      });
    }
  });
</script>
