---
interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;

const navLinks = [
  { href: "/projects", label: "Projects", i18n: "nav_projects" },
  { href: "/gaming", label: "Gaming", i18n: "nav_gaming" },
  { href: "/about", label: "About", i18n: "nav_about" },
];
---

<header
  id="site-header"
  class="sticky top-0 z-50 bg-bg/90 backdrop-blur-xl transition-all duration-300"
>
  <div class="mx-auto flex h-[60px] max-w-[1280px] items-center justify-between px-12 max-md:h-[52px] max-md:px-6">
    <!-- Brand: "DAVID LUKY" morphs to "DL" on scroll -->
    <a href="/" class="brand-mark group no-underline">
      <span class="brand-text"><span class="brand-keep">D</span><span class="brand-mid">avid</span><span class="brand-gap"></span><span class="brand-keep">L</span><span class="brand-mid">uky</span></span>
    </a>

    <!-- Desktop navigation -->
    <nav class="flex items-center gap-8 max-md:hidden">
      {navLinks.map(({ href, label, i18n }) => (
        <a
          href={href}
          data-i18n={i18n}
          class:list={[
            "text-sm no-underline transition-colors",
            currentPath === href ? "text-text" : "text-text-2 hover:text-text",
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="https://play.davidluky.com"
        target="_blank"
        rel="noopener noreferrer"
        data-i18n="nav_play"
        class="rounded-md bg-accent px-4 py-2 text-[13px] font-medium text-bg no-underline transition-opacity hover:opacity-90"
      >
        Play The Room
      </a>
    </nav>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-btn"
      class="mobile-menu-btn"
      aria-label="Menu"
      aria-expanded="false"
    >
      <svg id="menu-icon" class="w-5 h-5 text-text-2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="close-icon" class="w-5 h-5 text-text-2 pointer-events-none mobile-menu-closed" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <nav
    id="mobile-menu"
    class="mobile-menu-closed border-t border-border/20 bg-bg/95 backdrop-blur-xl"
  >
    <div class="mx-auto max-w-[1280px] px-6 py-5 flex flex-col gap-4">
      {navLinks.map(({ href, label, i18n }) => (
        <a
          href={href}
          data-i18n={i18n}
          class:list={[
            "text-[15px] no-underline transition-colors py-1",
            currentPath === href ? "text-text" : "text-text-2 hover:text-text",
          ]}
        >
          {label}
        </a>
      ))}
      <a
        href="https://play.davidluky.com"
        target="_blank"
        rel="noopener noreferrer"
        data-i18n="nav_play"
        class="mt-1 w-fit rounded-md bg-accent px-4 py-2 text-[13px] font-medium text-bg no-underline transition-opacity hover:opacity-90"
      >
        Play The Room
      </a>
    </div>
  </nav>
</header>

<!-- Scroll-triggered brand morph + mobile menu toggle -->
<script>
  const header = document.getElementById('site-header');
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  // Scroll morph
  if (header) {
    let scrolled = false;
    const onScroll = () => {
      const past = window.scrollY > 60;
      if (past !== scrolled) {
        scrolled = past;
        header.classList.toggle('header-scrolled', past);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Mobile menu toggle — uses inline styles to avoid CSS specificity issues
  if (menuBtn && mobileMenu && menuIcon && closeIcon) {
    let open = false;
    menuBtn.addEventListener('click', () => {
      open = !open;
      mobileMenu.style.display = open ? 'block' : 'none';
      menuIcon.style.display = open ? 'none' : 'block';
      closeIcon.style.display = open ? 'block' : 'none';
      menuBtn.setAttribute('aria-expanded', String(open));
    });
  }
</script>
