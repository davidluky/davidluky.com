---
interface Props {
  title: string;
  subtitle: string;
  cta?: { label: string; href: string };
}

const { title, subtitle, cta } = Astro.props;
---

<section class="relative overflow-hidden text-center">
  <!-- Radial gold glow background -->
  <div
    class="pointer-events-none absolute -top-[40%] left-1/2 h-[800px] w-[800px] -translate-x-1/2"
    style="background: radial-gradient(circle, rgba(196, 163, 90, 0.06) 0%, transparent 70%)"
  ></div>

  <div class="relative mx-auto max-w-[720px] px-12 pt-36 pb-28 max-md:px-6 max-md:pt-24 max-md:pb-20">
    <h1
      class="mb-5 text-[54px] font-light leading-[1.15] tracking-[-1.5px] max-md:text-4xl"
      set:html={title}
    />
    <p class="mx-auto mb-9 max-w-[520px] text-[19px] font-light leading-relaxed text-text-2">
      {subtitle}
    </p>
    {cta && (
      <a
        href={cta.href}
        class="inline-flex items-center gap-2 text-sm font-medium text-accent no-underline transition-[gap] hover:gap-3"
      >
        {cta.label}
        <span class="text-lg">&darr;</span>
      </a>
    )}
  </div>
</section>
