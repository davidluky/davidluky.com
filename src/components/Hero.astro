---
interface Props {
  title: string;
  subtitle: string;
  cta?: { label: string; href: string };
}

const { title, subtitle, cta } = Astro.props;
---

<section class="text-center">
  <div class="mx-auto max-w-[720px] px-12 pt-36 pb-28 max-md:px-6 max-md:pt-24 max-md:pb-20">
    <h1
      class="mb-5 text-[54px] font-light leading-[1.15] tracking-[-1.5px] max-md:text-4xl max-sm:text-3xl"
      set:html={title}
    />
    <p class="mx-auto mb-9 max-w-[520px] text-[19px] font-light leading-relaxed text-text-2 max-sm:text-base">
      {subtitle}
    </p>
    {cta && (
      <a
        href={cta.href}
        class="inline-flex items-center gap-2 text-sm font-medium text-accent no-underline transition-[gap] hover:gap-3"
      >
        {cta.label}
        <span class="text-lg">&darr;</span>
      </a>
    )}
  </div>
</section>
