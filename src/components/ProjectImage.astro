---
import { projectTags, type Project } from "../data/projects";

interface Props {
  project: Project;
  compact?: boolean;
  eager?: boolean;
  class?: string;
}

const { project, compact = false, eager = false, class: className = "" } = Astro.props;
const tag = projectTags[project.tag];
const alt = project.imageAlt ?? `${project.name} project preview`;
const altPt = project.imageAltPt ?? alt;
const fallbackNameClass = compact
  ? "text-[0.82rem]"
  : "text-[clamp(1.35rem,3vw,2.7rem)]";
const fallbackPadding = compact ? "p-4" : "p-5";
const fallbackTagClass = compact ? "text-[9px]" : "text-[11px]";
---

<div
  class:list={[
    "group/project-image relative overflow-hidden rounded-lg border border-border bg-[#0f0f0e]",
    compact ? "aspect-[16/10]" : "aspect-video",
    className,
  ]}
>
  {project.image ? (
    <img
      src={project.image}
      alt={alt}
      width="1200"
      height="675"
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      data-project-image-alt={project.id}
      data-alt-en={alt}
      data-alt-pt={altPt}
      class="h-full w-full object-cover transition-transform duration-500 group-hover/project-image:scale-[1.02]"
    />
  ) : (
    <div class={`flex h-full w-full flex-col justify-between bg-[radial-gradient(circle_at_75%_10%,rgba(211,173,76,0.12),transparent_34%),linear-gradient(135deg,#10110f,#070807)] ${fallbackPadding}`}>
      <span class={`font-mono ${fallbackTagClass} font-semibold uppercase tracking-[2px] ${tag.colorClass}`} data-project-tag={project.id}>
        {tag.label}
      </span>
      <span class={`max-w-full break-words font-mono ${fallbackNameClass} font-semibold uppercase leading-tight text-text/80`}>
        {project.name}
      </span>
    </div>
  )}
</div>
