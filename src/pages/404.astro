---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Not Found — David Luky" description="The page you're looking for doesn't exist.">
  <Header />

  <section class="mx-auto max-w-[1280px] px-12 py-40 text-center max-md:px-6 max-md:py-24">
    <div class="mb-4 text-6xl font-light text-text-3">404</div>
    <h1 class="mb-4 text-2xl font-light">Page not found</h1>
    <p class="mb-8 text-text-2">The page you're looking for doesn't exist or has been moved.</p>
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm font-medium text-accent no-underline transition-[gap] hover:gap-3"
    >
      &larr; Back to home
    </a>
  </section>

  <Footer />
</Base>
