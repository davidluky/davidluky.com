---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const techStack = {
  Languages: ["TypeScript", "C++17", "C", "Python", "Bash", "SQL"],
  Frontend: ["React 19", "Astro", "Tailwind CSS", "Vite", "Electron"],
  Backend: ["Node.js", "Next.js", "Firebase", "Supabase", "SQLite"],
  Tools: ["Git", "Cloudflare Workers", "Vercel", "PM2", "Ollama", "MCP"],
};

const timeline = [
  { year: "2010", text: "Created my Steam account — gaming became a daily thing" },
  { year: "2014", text: "Started playing Tibia — still active today at Level 627" },
  { year: "2020", text: "Built The Room — a multiplayer RPG platform in C++ with 13 games" },
  { year: "2024", text: "Expanded The Room to a full React web client with Firebase" },
  { year: "2025", text: "Built Tibia Services, Game Library, Local IA, and this site" },
];
---

<Base title="About — David Luky" description="Developer and lifelong gamer from Brazil. Learn more about David Luky.">
  <Header currentPath="/about" />

  <!-- Hero -->
  <section class="mx-auto max-w-[1280px] px-12 pt-36 pb-20 max-md:px-6 max-md:pt-24">
    <div data-i18n="a_label" class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
      About
    </div>
    <h1 data-i18n="a_title" class="mb-6 max-w-[620px] text-[42px] font-light leading-tight tracking-tight max-md:text-3xl">
      A bit about me
    </h1>
    <p data-i18n="a_intro" class="max-w-[600px] text-[17px] leading-[1.85] text-text-2">
      I'm David — a developer and lifelong gamer from Brazil. I build things that interest me, from multiplayer RPGs to automation bots to achievement unlockers. Most of my work lives on
      <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.
    </p>
  </section>

  <!-- Background -->
  <section class="mx-auto max-w-[1280px] px-12 pb-20 max-md:px-6">
    <h3 data-i18n="a_bg_label" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Background
    </h3>
    <div class="max-w-[600px] space-y-4">
      <p data-i18n="a_bg_p1" class="text-[15px] leading-[1.85] text-text-2">
        Gaming is what got me into programming. I wanted to understand how the things I loved were made — that curiosity turned into building my own games, tools, and platforms.
      </p>
      <p data-i18n="a_bg_p2" class="text-[15px] leading-[1.85] text-text-2">
        My main project is <a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a>, a multiplayer RPG platform with 13 games, 239 achievements, a full economy, and tournaments. It started as a C++ desktop application and grew into a React web client sharing the same Firebase backend.
      </p>
      <p data-i18n="a_bg_p3" class="text-[15px] leading-[1.85] text-text-2">
        Outside of that, I build whatever catches my attention — a WhatsApp bot for tracking gym check-ins, a marketplace for Tibia game services, a tool for reverse engineering Xbox achievement data, and various experiments with local AI models.
      </p>
    </div>
  </section>

  <!-- What I work with -->
  <section class="mx-auto max-w-[1280px] px-12 pb-20 max-md:px-6">
    <h3 data-i18n="a_tech_label" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      What I work with
    </h3>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {Object.entries(techStack).map(([category, techs]) => (
        <div>
          <div class="mb-3 text-[13px] font-medium text-text">{category}</div>
          <div class="flex flex-wrap gap-2">
            {techs.map((t) => (
              <span class="rounded bg-white/[0.04] px-2.5 py-1 font-mono text-[11px] text-text-3">
                {t}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <section class="mx-auto max-w-[1280px] px-12 pb-20 max-md:px-6">
    <h3 data-i18n="a_timeline_label" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Timeline
    </h3>
    <div class="space-y-0">
      {timeline.map((item) => (
        <div class="flex gap-6 border-b border-border/30 py-5 last:border-0 max-md:gap-4">
          <span class="w-12 shrink-0 font-mono text-[14px] font-medium text-accent">{item.year}</span>
          <span class="text-[15px] leading-relaxed text-text-2">{item.text}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section class="mx-auto max-w-[1280px] px-12 pb-24 max-md:px-6">
    <h3 data-i18n="a_contact_label" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Get in touch
    </h3>
    <p data-i18n="a_contact_text" class="max-w-[600px] text-[15px] leading-[1.85] text-text-2">
      Want to reach out? Send me an email at
      <a href="mailto:davidluky@davidluky.com" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">davidluky@davidluky.com</a>
      or find me on
      <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.
    </p>
  </section>

  <Footer />
</Base>

<script>
  import { applyI18n } from '../i18n/shared';
  applyI18n({
    en: {
      a_label: 'About',
      a_title: 'A bit about me',
      a_intro: 'I\'m David — a developer and lifelong gamer from Brazil. I build things that interest me, from multiplayer RPGs to automation bots to achievement unlockers. Most of my work lives on <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.',
      a_bg_label: 'Background',
      a_bg_p1: 'Gaming is what got me into programming. I wanted to understand how the things I loved were made — that curiosity turned into building my own games, tools, and platforms.',
      a_bg_p2: 'My main project is <a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a>, a multiplayer RPG platform with 13 games, 239 achievements, a full economy, and tournaments. It started as a C++ desktop application and grew into a React web client sharing the same Firebase backend.',
      a_bg_p3: 'Outside of that, I build whatever catches my attention — a WhatsApp bot for tracking gym check-ins, a marketplace for Tibia game services, a tool for reverse engineering Xbox achievement data, and various experiments with local AI models.',
      a_tech_label: 'What I work with',
      a_timeline_label: 'Timeline',
      a_contact_label: 'Get in touch',
      a_contact_text: 'Want to reach out? Send me an email at <a href="mailto:davidluky@davidluky.com" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">davidluky@davidluky.com</a> or find me on <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.',
    },
    pt: {
      a_label: 'Sobre',
      a_title: 'Um pouco sobre mim',
      a_intro: 'Eu sou o David — desenvolvedor e gamer de longa data do Brasil. Eu construo coisas que me interessam, de RPGs multiplayer a bots de automação e desbloqueadores de conquistas. A maioria do meu trabalho está no <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.',
      a_bg_label: 'Trajetória',
      a_bg_p1: 'Jogos foram o que me levaram à programação. Eu queria entender como as coisas que eu amava eram feitas — essa curiosidade se transformou em construir meus próprios jogos, ferramentas e plataformas.',
      a_bg_p2: 'Meu projeto principal é o <a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a>, uma plataforma RPG multiplayer com 13 jogos, 239 conquistas, economia completa e torneios. Começou como um aplicativo desktop em C++ e cresceu para um cliente web em React compartilhando o mesmo backend Firebase.',
      a_bg_p3: 'Fora isso, construo o que chama minha atenção — um bot de WhatsApp para rastrear check-ins na academia, um marketplace para serviços de Tibia, uma ferramenta para engenharia reversa de dados de conquistas do Xbox, e vários experimentos com modelos de IA locais.',
      a_tech_label: 'Com o que trabalho',
      a_timeline_label: 'Linha do tempo',
      a_contact_label: 'Entre em contato',
      a_contact_text: 'Quer entrar em contato? Me mande um email em <a href="mailto:davidluky@davidluky.com" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">davidluky@davidluky.com</a> ou me encontre no <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.',
    },
  });
</script>
