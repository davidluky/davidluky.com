---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { stats } from "../data/stats";

const techCategories = ["Languages", "Frontend", "Backend", "Tools"];
const techCategoriesPt = ["Linguagens", "Frontend", "Backend", "Ferramentas"];

const techStack: Record<string, string[]> = {
  Languages: ["TypeScript", "C++17", "C", "Python", "Dart", "Lua", "Bash", "SQL"],
  Frontend: ["React 19", "Astro", "Next.js", "Tailwind CSS", "Vite", "Electron", "Flutter", "raylib"],
  Backend: ["Node.js", "Firebase", "Supabase", "SQLite", "FastAPI"],
  Tools: ["Git", "Cloudflare Workers", "Vercel", "PM2", "Ollama", "MCP", "Vertex AI", "PyTorch", "PowerShell"],
};

const timeline = [
  { year: "2010", text: `Created my Steam account — gaming became a daily thing`, textPt: `Criei minha conta Steam — jogos viraram rotina diária` },
  { year: "2014", text: `Started playing Tibia and writing my first code — still active in both today (Tibia Level ${stats.tibiaLevel})`, textPt: `Comecei a jogar Tibia e escrever meu primeiro código — ainda ativo em ambos hoje (Tibia Level ${stats.tibiaLevel})` },
  { year: "2020", text: `Built The Room — a multiplayer RPG platform in C++ with ${stats.theRoomGames} games`, textPt: `Criei o The Room — uma plataforma RPG multiplayer em C++ com ${stats.theRoomGames} jogos` },
  { year: "2024", text: "Expanded The Room to a full React web client with Firebase", textPt: "Expandi o The Room para um cliente web completo em React com Firebase" },
  { year: "2025", text: "Built Tibia Services, Game Library, Local IA, and the first version of this portfolio", textPt: "Criei Tibia Services, Game Library, Local IA e a primeira versão deste portfólio" },
  { year: "2026", text: "Expanded into dual-curriculum math, trading-card arbitrage, Flutter mobile work, eBay compliance infrastructure, and AI/game-dev systems around Mega Man X", textPt: "Expandi para matemática com currículo duplo, arbitragem de cards, mobile com Flutter, infraestrutura de compliance do eBay e sistemas de IA/game-dev em torno de Mega Man X" },
];
---

<Base title="About — David Luky" description="Developer and lifelong gamer based in the US. Learn more about David Luky.">
  <Header currentPath="/about" />

  <!-- Hero -->
  <section class="mx-auto max-w-[1280px] px-12 pt-36 pb-20 max-md:px-6 max-md:pt-20">
    <div data-i18n="a_label" class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
      About
    </div>
    <h1 data-i18n="a_title" class="mb-6 max-w-[620px] text-[42px] font-light leading-tight tracking-tight max-md:text-3xl">
      A bit about me
    </h1>
    <p data-i18n="a_intro" data-i18n-html class="max-w-[600px] text-[17px] leading-[1.85] text-text-2">
      I'm David — a developer and lifelong gamer based in the US. I build things that interest me, from multiplayer RPGs to automation bots to achievement unlockers. Most of my work lives on
      <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.
    </p>
  </section>

  <!-- Background -->
  <section class="mx-auto max-w-[1280px] px-12 pb-20 max-md:px-6">
    <h2 data-i18n="a_bg_label" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Background
    </h2>
    <div class="max-w-[600px] space-y-4">
      <p data-i18n="a_bg_p1" class="text-[15px] leading-[1.85] text-text-2">
        Gaming is what got me into programming. I wanted to understand how the things I loved were made — that curiosity turned into building my own games, tools, and platforms.
      </p>
      <p data-i18n="a_bg_p2" data-i18n-html class="text-[15px] leading-[1.85] text-text-2">
        My main project is <a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a>, a multiplayer RPG platform with {stats.theRoomGames} games, {stats.theRoomAchievements} achievements, a full economy, and tournaments. It started as a C++ desktop application and grew into a React web client sharing the same Firebase backend.
      </p>
      <p data-i18n="a_bg_p3" class="text-[15px] leading-[1.85] text-text-2">
        Outside of that, I build whatever catches my attention: dual-curriculum math practice, trading-card arbitrage, Flutter mobile experiments, WhatsApp automation, AI asset pipelines, reverse-engineering tools, and game systems from scratch.
      </p>
    </div>
  </section>

  <!-- What I work with -->
  <section class="mx-auto max-w-[1280px] px-12 pb-20 max-md:px-6">
    <h2 data-i18n="a_tech_label" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      What I work with
    </h2>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      {techCategories.map((category, i) => (
        <div>
          <div class="mb-3 text-[13px] font-medium text-text" data-i18n-tech={`tech_${i}`}>{category}</div>
          <div class="flex flex-wrap gap-2">
            {techStack[category].map((t) => (
              <span class="rounded bg-white/[0.04] px-2.5 py-1 font-mono text-[11px] text-text-3">
                {t}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <section class="mx-auto max-w-[1280px] px-12 pb-20 max-md:px-6">
    <h2 data-i18n="a_timeline_label" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Timeline
    </h2>
    <div class="space-y-0">
      {timeline.map((item, i) => (
        <div class="flex gap-6 border-b border-border/30 py-5 last:border-0 max-md:gap-4">
          <span class="w-12 shrink-0 font-mono text-[14px] font-medium text-accent">{item.year}</span>
          <span class="text-[15px] leading-relaxed text-text-2" data-i18n-timeline={`tl_${i}`}>{item.text}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section class="mx-auto max-w-[1280px] px-12 pb-24 max-md:px-6">
    <h2 data-i18n="a_contact_label" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Get in touch
    </h2>
    <p data-i18n="a_contact_text" data-i18n-html class="max-w-[600px] text-[15px] leading-[1.85] text-text-2">
      Want to reach out? Send me an email at
      <a href="mailto:davidluky@davidluky.com" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">davidluky@davidluky.com</a>
      or find me on
      <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.
    </p>
  </section>

  <Footer />
</Base>

<script is:inline define:vars={{ timelinePt: timeline.map(t => t.textPt), techCategoriesPt, roomGames: stats.theRoomGames, roomAchievements: stats.theRoomAchievements }}>
  window.__about = { timelinePt, techCategoriesPt, roomGames, roomAchievements };
</script>
<script>
  import { applyI18n, getLanguage } from '../i18n/shared';

  const { timelinePt, techCategoriesPt, roomGames, roomAchievements } = window.__about;

  applyI18n({
    en: {
      a_label: 'About',
      a_title: 'A bit about me',
      a_intro: 'I\'m David — a developer and lifelong gamer based in the US. I build things that interest me, from multiplayer RPGs to automation bots to achievement unlockers. Most of my work lives on <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.',
      a_bg_label: 'Background',
      a_bg_p1: 'Gaming is what got me into programming. I wanted to understand how the things I loved were made — that curiosity turned into building my own games, tools, and platforms.',
      a_bg_p2: `My main project is <a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a>, a multiplayer RPG platform with ${roomGames} games, ${roomAchievements} achievements, a full economy, and tournaments. It started as a C++ desktop application and grew into a React web client sharing the same Firebase backend.`,
      a_bg_p3: 'Outside of that, I build whatever catches my attention: dual-curriculum math practice, trading-card arbitrage, Flutter mobile experiments, WhatsApp automation, AI asset pipelines, reverse-engineering tools, and game systems from scratch.',
      a_tech_label: 'What I work with',
      a_timeline_label: 'Timeline',
      a_contact_label: 'Get in touch',
      a_contact_text: 'Want to reach out? Send me an email at <a href="mailto:davidluky@davidluky.com" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">davidluky@davidluky.com</a> or find me on <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.',
    },
    pt: {
      a_label: 'Sobre',
      a_title: 'Um pouco sobre mim',
      a_intro: 'Eu sou o David — desenvolvedor e gamer de longa data baseado nos EUA. Eu construo coisas que me interessam, de RPGs multiplayer a bots de automação e desbloqueadores de conquistas. A maioria do meu trabalho está no <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.',
      a_bg_label: 'Trajetória',
      a_bg_p1: 'Jogos foram o que me levaram à programação. Eu queria entender como as coisas que eu amava eram feitas — essa curiosidade se transformou em construir meus próprios jogos, ferramentas e plataformas.',
      a_bg_p2: `Meu projeto principal é o <a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a>, uma plataforma RPG multiplayer com ${roomGames} jogos, ${roomAchievements} conquistas, economia completa e torneios. Começou como um aplicativo desktop em C++ e cresceu para um cliente web em React compartilhando o mesmo backend Firebase.`,
      a_bg_p3: 'Fora isso, construo o que chama minha atenção: prática de matemática com currículo duplo, arbitragem de cards, experimentos mobile em Flutter, automação de WhatsApp, pipelines de assets com IA, ferramentas de engenharia reversa e sistemas de jogo do zero.',
      a_tech_label: 'Com o que trabalho',
      a_timeline_label: 'Linha do tempo',
      a_contact_label: 'Entre em contato',
      a_contact_text: 'Quer entrar em contato? Me mande um email em <a href="mailto:davidluky@davidluky.com" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">davidluky@davidluky.com</a> ou me encontre no <a href="https://github.com/davidluky" class="border-b border-accent/30 text-accent no-underline transition-colors hover:border-accent">GitHub</a>.',
    },
  });

  const lang = getLanguage();
  if (lang === 'pt') {
    document.querySelectorAll('[data-i18n-timeline]').forEach(el => {
      const idx = Number(el.getAttribute('data-i18n-timeline')!.replace('tl_', ''));
      if (timelinePt[idx]) el.textContent = timelinePt[idx];
    });
    document.querySelectorAll('[data-i18n-tech]').forEach(el => {
      const idx = Number(el.getAttribute('data-i18n-tech')!.replace('tech_', ''));
      if (techCategoriesPt[idx]) el.textContent = techCategoriesPt[idx];
    });
  }
</script>
