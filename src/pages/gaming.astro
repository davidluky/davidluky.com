---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { stats } from "../data/stats";
import { loadGamingData } from "../data/gaming";

const gaming = await loadGamingData();

const fmt = (n: number) => n.toLocaleString("en-US");

const platformColors: Record<string, string> = {
  steam: "#1b2838",
  xbox: "#107c10",
  epic: "#2a2a2a",
  tibia: "#4a2800",
};

const platformTextColors: Record<string, string> = {
  steam: "#66c0f4",
  xbox: "#fff",
  epic: "#fff",
  tibia: "#f0c040",
};

const platformLabel = (p: string) => {
  const map: Record<string, string> = { steam: "Steam", xbox: "Xbox", epic: "Epic", "gamepass-pc": "GP PC", "gamepass-xbox": "GP Xbox" };
  return map[p] ?? p;
};

const mostPlayedTotal = gaming.mostPlayed.reduce((s, g) => s + g.hours, 0);
const gamesWithHours = gaming.distribution.over100h + gaming.distribution.h10to100 + gaming.distribution.h1to10 + gaming.distribution.under1h;
---

<Base title="Gaming — David Luky" description="Where I play: Steam, Xbox, Epic Games, and Tibia gaming profiles.">
  <Header currentPath="/gaming" />

  <section class="mx-auto max-w-[1280px] px-12 pt-36 pb-20 max-md:px-6 max-md:pt-20">
    <div data-i18n="g_label" class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
      Gaming
    </div>
    <h1 data-i18n="g_title" class="mb-6 max-w-[620px] text-[42px] font-light leading-tight tracking-tight max-md:text-3xl">
      Where I play
    </h1>
    <p data-i18n="g_subtitle" class="max-w-[560px] text-[17px] leading-relaxed text-text-2">
      Gaming is what got me into programming — I wanted to understand how the things I loved were made, and that curiosity never went away.
    </p>
  </section>

  <!-- Overview -->
  <section class="mx-auto max-w-[1280px] px-12 pb-14 max-md:px-6">
    <h3 data-i18n="g_overview" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Overview
    </h3>
    <div class="grid grid-cols-2 gap-4 max-sm:gap-3 md:grid-cols-4 lg:grid-cols-6">
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{fmt(gaming.totalGames)}</div>
        <div data-i18n="g_stat_games" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Games Owned</div>
        <div data-i18n="g_stat_games_sub" class="mt-2 text-[11px] text-text-3">Steam + Epic</div>
      </div>
      <div class="hours-tile relative rounded-xl bg-[#0f0f0e] p-6 cursor-pointer">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{fmt(gaming.totalHours)}</div>
        <div data-i18n="g_stat_hours" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Hours Played</div>
        <div data-i18n="g_stat_hours_sub" class="mt-2 text-[11px] text-text-3">Across all platforms</div>
        <div class="hours-tooltip">
          {gaming.hoursByPlatform.map(p => (
            <div class="flex justify-between gap-6 py-1">
              <span class="text-text-2">{p.platform}</span>
              <span class="font-mono text-text">{fmt(p.hours)}h</span>
            </div>
          ))}
        </div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{gamesWithHours}</div>
        <div data-i18n="g_stat_played" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Games Played</div>
        <div data-i18n="g_stat_played_sub" class="mt-2 text-[11px] text-text-3">With tracked hours</div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{stats.gamingPlatforms}</div>
        <div data-i18n="g_stat_platforms" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Platforms</div>
        <div data-i18n="g_stat_platforms_sub" class="mt-2 text-[11px] text-text-3">Steam, Xbox, Epic, Tibia</div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{stats.yearsGaming}</div>
        <div data-i18n="g_stat_years" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Years Gaming</div>
        <div data-i18n="g_stat_years_sub" class="mt-2 text-[11px] text-text-3">On Steam since 2010</div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{stats.tibiaLevel}</div>
        <div data-i18n="g_stat_tibia" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Tibia Level</div>
        <div data-i18n="g_stat_tibia_sub" class="mt-2 text-[11px] text-text-3">Elder Druid, Jadebra</div>
      </div>
    </div>
  </section>

  <!-- Platform breakdown -->
  <section class="mx-auto max-w-[1280px] px-12 pb-16 max-md:px-6">
    <div class="grid gap-5 max-sm:gap-3 md:grid-cols-2">
      <!-- Steam -->
      <div class="rounded-xl border border-border bg-bg-card p-7 max-sm:p-4">
        <div class="mb-5 flex items-center gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[#1b2838] text-lg font-bold text-[#66c0f4]">S</div>
          <div>
            <h3 class="text-[15px] font-medium">Steam</h3>
            <a href="https://steamcommunity.com/id/DavidLuky" class="font-mono text-[13px] text-text-2 no-underline hover:text-accent transition-colors">David Luky</a>
          </div>
          <div class="ml-auto text-right">
            <div class="text-lg font-light text-text">Lvl {stats.steamLevel}</div>
            <div data-i18n="g_steam_count" class="text-[11px] text-text-3">{fmt(gaming.ownedByPlatform.steam ?? 0)} games</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 text-[12px] text-text-3">
          <span>Dota 2 <span class="text-text-2">{stats.steamHoursDota}h</span></span>
          <span class="text-border">&middot;</span>
          <span>Terraria <span class="text-text-2">{stats.steamHoursTerraria}h</span></span>
          <span class="text-border">&middot;</span>
          <span data-i18n="g_steam_perfect">{stats.steamPerfectGames} perfect games</span>
          <span class="text-border">&middot;</span>
          <span data-i18n="g_steam_friends">{stats.steamFriends} friends</span>
        </div>
      </div>

      <!-- Xbox -->
      <div class="rounded-xl border border-border bg-bg-card p-7 max-sm:p-4">
        <div class="mb-5 flex items-center gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[#107c10] text-lg font-bold text-white">X</div>
          <div>
            <h3 class="text-[15px] font-medium">Xbox</h3>
            <span class="font-mono text-[13px] text-text-2">David Luky</span>
          </div>
          <div class="ml-auto text-right">
            <div class="text-lg font-light text-text">Series X</div>
            <div class="text-[11px] text-text-3">Game Pass</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 text-[12px] text-text-3">
          <span data-i18n="g_xbox_games">{stats.xboxGames} games</span>
          <span class="text-border">&middot;</span>
          <span data-i18n="g_xbox_gs">{stats.xboxGamerscore} gamerscore</span>
          <span class="text-border">&middot;</span>
          <span data-i18n="g_xbox_gp">{stats.xboxGamePassTitles} Game Pass titles</span>
        </div>
      </div>

      <!-- Tibia -->
      <div class="rounded-xl border border-border bg-bg-card p-7 max-sm:p-4">
        <div class="mb-5 flex items-center gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[#4a2800] text-lg font-bold text-[#f0c040]">T</div>
          <div>
            <h3 class="text-[15px] font-medium">Tibia</h3>
            <a href="https://www.tibia.com/community/?subtopic=characters&name=David+Luky+Pobre" class="font-mono text-[13px] text-text-2 no-underline hover:text-accent transition-colors">David Luky Pobre</a>
          </div>
          <div class="ml-auto text-right">
            <div class="text-lg font-light text-text">Lvl {stats.tibiaLevel}</div>
            <div class="text-[11px] text-text-3">Elder Druid</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 text-[12px] text-text-3">
          <span>Jadebra</span>
          <span class="text-border">&middot;</span>
          <span>Jadebraland Encore</span>
          <span class="text-border">&middot;</span>
          <span data-i18n="g_tibia_pts">{stats.tibiaAchievementPts} achievement pts</span>
          <span class="text-border">&middot;</span>
          <span data-i18n="g_tibia_since">Since {stats.tibiaStartYear}</span>
          <span class="text-border">&middot;</span>
          <span data-i18n="g_tibia_titles">{stats.tibiaTitles} titles</span>
        </div>
      </div>

      <!-- Epic Games -->
      <div class="rounded-xl border border-border bg-bg-card p-7 max-sm:p-4">
        <div class="mb-5 flex items-center gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-[#2a2a2a] text-lg font-bold text-white">E</div>
          <div>
            <h3 class="text-[15px] font-medium">Epic Games</h3>
            <span class="font-mono text-[13px] text-text-2">David Luky</span>
          </div>
          <div class="ml-auto text-right">
            <div class="text-lg font-light text-text">{fmt(gaming.ownedByPlatform.epic ?? 281)}</div>
            <div data-i18n="g_epic_count" class="text-[11px] text-text-3">games</div>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 text-[12px] text-text-3">
          <span data-i18n="g_epic_desc">Free game collector since the early giveaways</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Recently played -->
  <section class="mx-auto max-w-[1280px] px-12 pb-16 max-md:px-6">
    <h3 data-i18n="g_recent" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Recently Played
    </h3>
    <div class="space-y-0">
      {gaming.recentGames.map((game, i) => (
        <div class="flex items-center gap-5 max-sm:gap-3 border-b border-border/50 py-4 max-sm:py-2.5 last:border-0">
          <span class="w-6 shrink-0 text-right font-mono text-[13px] text-text-3">{i + 1}</span>
          <div class="flex-1 min-w-0">
            <span class="text-[15px] font-medium truncate block">{game.name}</span>
            {game.lastPlayed && (
              <span class="text-[11px] text-text-3">{game.lastPlayed}</span>
            )}
          </div>
          <span
            class="rounded px-2 py-0.5 text-[11px] font-medium shrink-0"
            style={`background: ${platformColors[game.platform] ?? "#2a2a2a"}; color: ${platformTextColors[game.platform] ?? "#fff"};`}
          >
            {platformLabel(game.platform)}
          </span>
          <span class="w-16 shrink-0 text-right font-mono text-[14px] text-text-2">{fmt(game.hours)}h</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Most played -->
  <section class="mx-auto max-w-[1280px] px-12 pb-16 max-md:px-6">
    <h3 data-i18n="g_most_played" class="mb-2 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Most Played
    </h3>
    <p data-i18n="g_most_played_desc" class="mb-5 text-[13px] text-text-3">
      Top {gaming.mostPlayed.length} games by playtime — tracked via <a href="/projects" class="text-text-2 no-underline hover:text-accent transition-colors">Game Library</a>, a desktop app I built to aggregate games across platforms.
    </p>
    <div class="space-y-0">
      {gaming.mostPlayed.map((game, i) => {
        const barWidth = Math.max(2, Math.round((game.hours / gaming.mostPlayed[0].hours) * 100));
        return (
          <div class="flex items-center gap-5 max-sm:gap-3 border-b border-border/50 py-3.5 max-sm:py-2 last:border-0 group">
            <span class="w-6 shrink-0 text-right font-mono text-[13px] text-text-3">{i + 1}</span>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3">
                <span class="text-[14px] truncate">{game.name}</span>
              </div>
              <div class="mt-1 h-[3px] rounded-full bg-white/[0.03]">
                <div class="h-full rounded-full bg-accent/40" style={`width: ${barWidth}%`}></div>
              </div>
            </div>
            <span
              class="rounded px-2 py-0.5 text-[11px] font-medium shrink-0"
              style={`background: ${platformColors[game.platform] ?? "#2a2a2a"}; color: ${platformTextColors[game.platform] ?? "#fff"};`}
            >
              {platformLabel(game.platform)}
            </span>
            <span class="w-16 shrink-0 text-right font-mono text-[13px] text-text-2">{fmt(game.hours)}h</span>
          </div>
        );
      })}
    </div>
    <div data-i18n="g_most_played_total" class="mt-4 text-[12px] text-text-3">
      {fmt(mostPlayedTotal)} hours across these {gaming.mostPlayed.length} titles
    </div>
  </section>

  <!-- Playtime distribution -->
  <section class="mx-auto max-w-[1280px] px-12 pb-16 max-md:px-6">
    <h3 data-i18n="g_distribution" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Playtime Distribution
    </h3>
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-accent mb-1">{gaming.distribution.over100h}</div>
        <div class="text-[11px] font-medium uppercase tracking-wider text-text-3">100+ hours</div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{gaming.distribution.h10to100}</div>
        <div class="text-[11px] font-medium uppercase tracking-wider text-text-3">10–100 hours</div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{gaming.distribution.h1to10}</div>
        <div class="text-[11px] font-medium uppercase tracking-wider text-text-3">1–10 hours</div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{gaming.distribution.under1h}</div>
        <div class="text-[11px] font-medium uppercase tracking-wider text-text-3">&lt; 1 hour</div>
      </div>
    </div>
  </section>

  <!-- Hardware -->
  <section class="mx-auto max-w-[1280px] px-12 pb-24 max-md:px-6">
    <h3 data-i18n="g_hardware" class="mb-5 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
      Hardware
    </h3>
    <div class="flex flex-wrap gap-3">
      <span class="rounded-lg border border-border bg-bg-card px-4 py-2.5 text-sm text-text-2">Xbox Series X</span>
      <span class="rounded-lg border border-border bg-bg-card px-4 py-2.5 text-sm text-text-2">Nintendo Switch</span>
      <span class="rounded-lg border border-border bg-bg-card px-4 py-2.5 text-sm text-text-2">PC</span>
    </div>
  </section>

  {gaming.source !== "fallback" && (
    <div class="mx-auto max-w-[1280px] px-12 pb-8 max-md:px-6">
      <p class="text-[11px] text-text-3/50">
        Data sourced from {gaming.source === "game-library" ? "Game Library" : "Steam API"} at build time. Last synced: {new Date().toISOString().slice(0, 10)}.
      </p>
    </div>
  )}

  <Footer />
</Base>

<script is:inline define:vars={{
  totalGames: gaming.totalGames,
  totalHours: gaming.totalHours,
  gamesWithHours,
  mostPlayedCount: gaming.mostPlayed.length,
  mostPlayedTotal,
  steamGames: gaming.ownedByPlatform.steam ?? 0,
  epicGames: gaming.ownedByPlatform.epic ?? 281,
}}>
  window.__gaming = { totalGames, totalHours, gamesWithHours, mostPlayedCount, mostPlayedTotal, steamGames, epicGames };
</script>
<script>
  import { applyI18n } from '../i18n/shared';
  import { stats } from '../data/stats';

  const g = (window as any).__gaming;
  const fmt = (n: number) => n.toLocaleString('en-US');
  const fmtPt = (n: number) => n.toLocaleString('pt-BR');

  applyI18n({
    en: {
      g_label: 'Gaming',
      g_title: 'Where I play',
      g_subtitle: 'Gaming is what got me into programming — I wanted to understand how the things I loved were made, and that curiosity never went away.',
      g_overview: 'Overview',
      g_stat_games: 'Games Owned',
      g_stat_games_sub: 'Steam + Epic',
      g_stat_hours: 'Hours Played',
      g_stat_hours_sub: 'Across all platforms',
      g_stat_played: 'Games Played',
      g_stat_played_sub: 'With tracked hours',
      g_stat_platforms: 'Platforms',
      g_stat_platforms_sub: 'Steam, Xbox, Epic, Tibia',
      g_stat_years: 'Years Gaming',
      g_stat_years_sub: `On Steam since ${stats.steamStartYear}`,
      g_stat_tibia: 'Tibia Level',
      g_stat_tibia_sub: 'Elder Druid, Jadebra',
      g_steam_count: `${fmt(g.steamGames)} games`,
      g_steam_perfect: `${stats.steamPerfectGames} perfect games`,
      g_steam_friends: `${stats.steamFriends} friends`,
      g_xbox_games: `${stats.xboxGames} games`,
      g_xbox_gs: `${stats.xboxGamerscore} gamerscore`,
      g_xbox_gp: `${stats.xboxGamePassTitles} Game Pass titles`,
      g_tibia_pts: `${stats.tibiaAchievementPts} achievement pts`,
      g_tibia_since: `Since ${stats.tibiaStartYear}`,
      g_tibia_titles: `${stats.tibiaTitles} titles`,
      g_epic_count: 'games',
      g_epic_desc: 'Free game collector since the early giveaways',
      g_recent: 'Recently Played',
      g_most_played: 'Most Played',
      g_most_played_desc: `Top ${g.mostPlayedCount} games by playtime — tracked via <a href="/projects" class="text-text-2 no-underline hover:text-accent transition-colors">Game Library</a>, a desktop app I built to aggregate games across platforms.`,
      g_most_played_total: `${fmt(g.mostPlayedTotal)} hours across these ${g.mostPlayedCount} titles`,
      g_distribution: 'Playtime Distribution',
      g_hardware: 'Hardware',
    },
    pt: {
      g_label: 'Jogos',
      g_title: 'Onde eu jogo',
      g_subtitle: 'Jogos foram o que me levaram à programação — eu queria entender como as coisas que eu amava eram feitas, e essa curiosidade nunca foi embora.',
      g_overview: 'Visão Geral',
      g_stat_games: 'Jogos Possuídos',
      g_stat_games_sub: 'Steam + Epic',
      g_stat_hours: 'Horas Jogadas',
      g_stat_hours_sub: 'Em todas as plataformas',
      g_stat_played: 'Jogos Jogados',
      g_stat_played_sub: 'Com horas rastreadas',
      g_stat_platforms: 'Plataformas',
      g_stat_platforms_sub: 'Steam, Xbox, Epic, Tibia',
      g_stat_years: 'Anos Jogando',
      g_stat_years_sub: `Na Steam desde ${stats.steamStartYear}`,
      g_stat_tibia: 'Nível no Tibia',
      g_stat_tibia_sub: 'Druida Ancião, Jadebra',
      g_steam_count: `${fmtPt(g.steamGames)} jogos`,
      g_steam_perfect: `${stats.steamPerfectGames} jogos perfeitos`,
      g_steam_friends: `${stats.steamFriends} amigos`,
      g_xbox_games: `${stats.xboxGames} jogos`,
      g_xbox_gs: `${stats.xboxGamerscore} gamerscore`,
      g_xbox_gp: `${stats.xboxGamePassTitles} títulos do Game Pass`,
      g_tibia_pts: `${stats.tibiaAchievementPts} pts de conquistas`,
      g_tibia_since: `Desde ${stats.tibiaStartYear}`,
      g_tibia_titles: `${stats.tibiaTitles} títulos`,
      g_epic_count: 'jogos',
      g_epic_desc: 'Coletor de jogos grátis desde as primeiras promoções',
      g_recent: 'Jogados Recentemente',
      g_most_played: 'Mais Jogados',
      g_most_played_desc: `Top ${g.mostPlayedCount} jogos por tempo de jogo — rastreado via <a href="/projects" class="text-text-2 no-underline hover:text-accent transition-colors">Game Library</a>, um app desktop que eu construí para agregar jogos de várias plataformas.`,
      g_most_played_total: `${fmtPt(g.mostPlayedTotal)} horas nesses ${g.mostPlayedCount} títulos`,
      g_distribution: 'Distribuição de Tempo',
      g_hardware: 'Hardware',
    },
  });
</script>
