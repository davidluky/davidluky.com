---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

/*
 * Gaming platform profiles.
 * Update the `handle` fields with actual usernames once provided.
 * `profileUrl` is optional — set to null if no public profile page exists.
 */
const platforms = [
  {
    name: "Steam",
    handle: "—",
    profileUrl: null,
    color: { bg: "#1b2838", text: "#66c0f4" },
    icon: "S",
    description: "PC gaming library, achievements, and community.",
  },
  {
    name: "Xbox",
    handle: "—",
    profileUrl: null,
    color: { bg: "#107c10", text: "#ffffff" },
    icon: "X",
    description: "Xbox Gamertag for Game Pass, multiplayer, and achievements.",
  },
  {
    name: "PlayStation",
    handle: "—",
    profileUrl: null,
    color: { bg: "#003087", text: "#ffffff" },
    icon: "P",
    description: "PlayStation Network ID for PS4/PS5 games and trophies.",
  },
  {
    name: "Tibia",
    handle: "—",
    profileUrl: null,
    color: { bg: "#4a2800", text: "#f0c040" },
    icon: "T",
    description: "Classic MMORPG character. Exploring the lands since day one.",
  },
];
---

<Base title="Gaming — David Luky" description="Where I play: Steam, Xbox, PlayStation, and Tibia gaming profiles.">
  <Header currentPath="/gaming" />

  <section class="mx-auto max-w-[1280px] px-12 pt-36 pb-20 max-md:px-6 max-md:pt-24">
    <div class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
      Gaming
    </div>
    <h1 class="mb-6 max-w-[620px] text-[42px] font-light leading-tight tracking-tight max-md:text-3xl">
      Where I play
    </h1>
    <p class="max-w-[560px] text-[17px] leading-relaxed text-text-2">
      Gaming is what got me into programming. Here are the platforms where you can find me.
    </p>
  </section>

  <section class="mx-auto max-w-[1280px] px-12 pb-24 max-md:px-6">
    <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
      {platforms.map((platform) => (
        <div class="group rounded-xl border border-border bg-bg-card p-7 transition-colors hover:border-border hover:bg-[#22211e]">
          <div class="mb-5 flex items-center gap-4">
            <div
              class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg text-lg font-bold"
              style={`background: ${platform.color.bg}; color: ${platform.color.text};`}
            >
              {platform.icon}
            </div>
            <div>
              <h2 class="text-[15px] font-medium">{platform.name}</h2>
              <span class="font-mono text-[13px] text-text-2">{platform.handle}</span>
            </div>
          </div>
          <p class="text-sm leading-relaxed text-text-2">{platform.description}</p>
          {platform.profileUrl && (
            <a
              href={platform.profileUrl}
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-accent no-underline"
            >
              View profile &rarr;
            </a>
          )}
        </div>
      ))}
    </div>
  </section>

  <Footer />
</Base>
