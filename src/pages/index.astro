---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/projects";
import { stats } from "../data/stats";

const liveSites = projects.filter(p => p.link && p.link.startsWith("http")).length;
---

<Base>
  <Header currentPath="/" />

  <Hero
    title="Developer. Gamer.<br>Builder of things."
    subtitle="Building multiplayer games and small tools that solve problems I care about. Based in the US."
    cta={{ label: "Continue reading", href: "#intro" }}
  />

  <!-- Introduction + Stats 2x2 grid -->
  <section id="intro" class="mx-auto max-w-[1280px] px-12 py-[88px] max-md:px-6 max-md:py-16">
    <div class="flex items-start gap-16 max-md:flex-col">
      <!-- Left: prose -->
      <div class="flex-1">
        <div data-i18n="intro_label" class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
          Introduction
        </div>
        <h2 data-i18n="intro_heading" class="mb-5 max-w-[620px] text-[30px] font-light leading-snug tracking-tight max-sm:text-[22px]">
          Most of what I build starts as something I want to use myself.
        </h2>
        <p data-i18n="intro_p1" class="mb-4 max-w-[600px] text-[17px] leading-[1.85] text-text-2">
          <a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a>
          is a multiplayer RPG platform — {stats.theRoomGames} games, achievements, economy, tournaments. It started as a C++ desktop application and has since expanded to a
          <em class="not-italic font-medium text-text">full web client</em>
          built with React, TypeScript, and Firebase.
        </p>
        <p data-i18n="intro_p2" class="max-w-[600px] text-[17px] leading-[1.85] text-text-2">
          I also build smaller things when a problem catches my attention: a
          <em class="not-italic font-medium text-text">WhatsApp bot</em>
          for automating gym check-ins, a tool for
          <em class="not-italic font-medium text-text">reverse engineering</em>
          game achievement data on legacy platforms, and various experiments that never quite leave the prototype stage.
        </p>
      </div>

      <!-- Right: 2x3 stats grid -->
      <div class="grid grid-cols-2 gap-6 shrink-0 max-md:w-full max-sm:gap-4 md:w-[320px]">
        <a href="/projects" class="rounded-xl bg-[#0f0f0e] p-6 no-underline transition-colors hover:bg-[#141413]">
          <div class="text-4xl font-light tracking-tight text-text mb-2">{projects.length}</div>
          <div data-i18n="stat_projects" class="text-[12px] font-medium uppercase tracking-wider text-text-3">Active Projects</div>
        </a>
        <a href="https://play.davidluky.com" target="_blank" rel="noopener noreferrer" class="rounded-xl bg-[#0f0f0e] p-6 no-underline transition-colors hover:bg-[#141413]">
          <div class="text-4xl font-light tracking-tight text-text mb-2">{stats.theRoomGames}</div>
          <div data-i18n="stat_games_room" class="text-[12px] font-medium uppercase tracking-wider text-accent/70">Games in The Room</div>
        </a>
        <a href="/gaming" class="rounded-xl bg-[#0f0f0e] p-6 no-underline transition-colors hover:bg-[#141413]">
          <div class="text-4xl font-light tracking-tight text-text mb-2">{stats.gamingPlatforms}</div>
          <div data-i18n="stat_gaming" class="text-[12px] font-medium uppercase tracking-wider text-text-3">Gaming Platforms</div>
        </a>
        <div class="live-sites-tile relative rounded-xl bg-[#0f0f0e] p-6 cursor-pointer transition-colors hover:bg-[#141413]">
          <div class="text-4xl font-light tracking-tight text-text mb-2">{liveSites}</div>
          <div data-i18n="stat_sites" class="text-[12px] font-medium uppercase tracking-wider text-text-3">Live Sites</div>
          <div class="live-sites-tooltip">
            {projects.filter(p => p.link?.startsWith("http")).map(p => (
              <a href={p.link!} target="_blank" rel="noopener noreferrer" class="live-sites-link">
                <span class="live-sites-name">{p.name}</span>
                <span class="live-sites-url">{p.link!.replace("https://", "")}</span>
              </a>
            ))}
          </div>
        </div>
        <div class="achievements-tile relative rounded-xl bg-[#0f0f0e] p-6 cursor-pointer transition-colors hover:bg-[#141413]">
          <div class="text-4xl font-light tracking-tight text-text mb-2">{stats.theRoomAchievements}</div>
          <div data-i18n="stat_achievements" class="text-[12px] font-medium uppercase tracking-wider text-text-3">Achievements</div>
          <div id="achievements-tooltip" class="achievements-tooltip" data-i18n="stat_achievements_tip">The real achievements are the traumas we acquired along the way!</div>
        </div>
        <!-- Language toggle card -->
        <button id="lang-toggle" class="rounded-xl bg-[#0f0f0e] p-6 text-left cursor-pointer transition-colors hover:bg-[#141413] group">
          <div class="text-4xl font-light tracking-tight text-text mb-2">2</div>
          <div data-i18n="stat_lang" class="text-[12px] font-medium uppercase tracking-wider text-text-3 mb-2">Languages</div>
          <div class="flex gap-1.5 text-[11px] font-semibold">
            <span id="lang-en" class="rounded px-2 py-0.5 bg-accent/20 text-accent transition-colors">EN</span>
            <span id="lang-pt" class="rounded px-2 py-0.5 bg-transparent text-text-3 transition-colors">PT</span>
          </div>
        </button>
      </div>
    </div>
  </section>

  <Footer />
</Base>

<script is:inline define:vars={{ roomGames: stats.theRoomGames, roomAchievements: stats.theRoomAchievements }}>
  window.__stats = { roomGames, roomAchievements };
</script>
<script>
  import { applyI18n } from '../i18n/shared';

  const pageStrings = {
    en: {
      hero_title: 'Developer. Gamer.<br>Builder of things.',
      hero_subtitle: 'Building multiplayer games and small tools that solve problems I care about. Based in the US.',
      hero_cta: 'Continue reading',
      intro_label: 'Introduction',
      intro_heading: 'Most of what I build starts as something I want to use myself.',
      intro_p1: `<a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a> is a multiplayer RPG platform — ${(window as any).__stats.roomGames} games, achievements, economy, tournaments. It started as a C++ desktop application and has since expanded to a <em class="not-italic font-medium text-text">full web client</em> built with React, TypeScript, and Firebase.`,
      intro_p2: 'I also build smaller things when a problem catches my attention: a <em class="not-italic font-medium text-text">WhatsApp bot</em> for automating gym check-ins, a tool for <em class="not-italic font-medium text-text">reverse engineering</em> game achievement data on legacy platforms, and various experiments that never quite leave the prototype stage.',
      stat_projects: 'Active Projects',
      stat_games_room: 'Games in The Room',
      stat_gaming: 'Gaming Platforms',
      stat_sites: 'Live Sites',
      stat_achievements: 'Achievements',
      stat_achievements_tip: 'The real achievements are the traumas we acquired along the way!',
      stat_lang: 'Languages',
    },
    pt: {
      hero_title: 'Desenvolvedor. Gamer.<br>Construtor de coisas.',
      hero_subtitle: 'Criando jogos multiplayer e pequenas ferramentas que resolvem problemas que me importam. Baseado nos EUA.',
      hero_cta: 'Continue lendo',
      intro_label: 'Introdução',
      intro_heading: 'A maioria do que eu construo começa como algo que eu mesmo quero usar.',
      intro_p1: `<a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a> é uma plataforma RPG multiplayer — ${(window as any).__stats.roomGames} jogos, conquistas, economia e torneios. Começou como um aplicativo desktop em C++ e desde então se expandiu para um <em class="not-italic font-medium text-text">cliente web completo</em> feito com React, TypeScript e Firebase.`,
      intro_p2: 'Também construo coisas menores quando um problema chama minha atenção: um <em class="not-italic font-medium text-text">bot de WhatsApp</em> para automatizar check-ins na academia, uma ferramenta para <em class="not-italic font-medium text-text">engenharia reversa</em> de dados de conquistas em plataformas legadas, e vários experimentos que nunca saem da fase de protótipo.',
      stat_projects: 'Projetos Ativos',
      stat_games_room: 'Jogos em The Room',
      stat_gaming: 'Plataformas de Jogos',
      stat_sites: 'Sites Online',
      stat_achievements: 'Conquistas',
      stat_achievements_tip: 'As verdadeiras conquistas são os traumas que adquirimos pelo caminho!',
      stat_lang: 'Idiomas',
    },
  };

  function updateHeroAndPills(lang: string) {
    const s = pageStrings[lang as keyof typeof pageStrings];
    const heroH1 = document.querySelector('section.text-center h1');
    const heroP = document.querySelector('section.text-center p');
    const heroCta = document.querySelector('section.text-center a');
    if (heroH1) heroH1.innerHTML = s.hero_title;
    if (heroP) heroP.textContent = s.hero_subtitle;
    if (heroCta) {
      heroCta.innerHTML = s.hero_cta + ' <span class="text-lg">&darr;</span>';
    }

    const enPill = document.getElementById('lang-en');
    const ptPill = document.getElementById('lang-pt');
    if (enPill && ptPill) {
      enPill.className = lang === 'en'
        ? 'rounded px-1.5 py-0.5 bg-accent/20 text-accent transition-colors'
        : 'rounded px-1.5 py-0.5 bg-transparent text-text-3 transition-colors';
      ptPill.className = lang === 'pt'
        ? 'rounded px-1.5 py-0.5 bg-accent/20 text-accent transition-colors'
        : 'rounded px-1.5 py-0.5 bg-transparent text-text-3 transition-colors';
    }
  }

  let lang = applyI18n(pageStrings);
  updateHeroAndPills(lang);

  document.getElementById('lang-toggle')?.addEventListener('click', () => {
    lang = lang === 'en' ? 'pt' : 'en';
    localStorage.setItem('dl-lang', lang);
    applyI18n(pageStrings);
    updateHeroAndPills(lang);
  });
</script>
