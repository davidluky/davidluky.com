---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import ProjectImage from "../components/ProjectImage.astro";
import { liveProjects, projects } from "../data/projects";
import { socialProfiles } from "../data/socials";
import { stats } from "../data/stats";

const roomWebProject = projects.find((project) => project.id === "the-room-web")!;
---

<Base title="David Luky - Projects, Games, and Online Presence" description="Portfolio hub for David Luky's projects, games, tools, writing, public profiles, and online presence.">
  <Header currentPath="/" />

  <Hero
    title="Developer. Gamer.<br>Builder of things."
    subtitle="Portfolio hub for the projects, games, tools, writing, and public profiles I keep shaping."
    cta={{ label: "Continue reading", href: "#intro" }}
  />

  <section id="intro" class="mx-auto max-w-[1280px] px-12 py-[88px] max-md:px-6 max-md:py-16">
    <div class="flex items-start gap-16 max-md:flex-col">
      <div class="flex-1">
        <div data-i18n="intro_label" class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
          Introduction
        </div>
        <h2 data-i18n="intro_heading" class="mb-5 max-w-[620px] text-[30px] font-light leading-snug tracking-tight max-sm:text-[22px]">
          Most of what I build starts as something I want to use myself.
        </h2>
        <p data-i18n="intro_p1" data-i18n-html class="mb-4 max-w-[600px] text-[17px] leading-[1.85] text-text-2">
          <a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a>
          is a multiplayer RPG platform - {stats.theRoomGames} games, achievements, economy, tournaments. It started as a C++ desktop application and has since expanded to a
          <em class="not-italic font-medium text-text">full web client</em>
          built with React, TypeScript, and Firebase.
        </p>
        <p data-i18n="intro_p2" data-i18n-html class="max-w-[600px] text-[17px] leading-[1.85] text-text-2">
          I also build smaller things when a problem catches my attention: a
          <em class="not-italic font-medium text-text">WhatsApp bot</em>
          for automating gym check-ins, a tool for
          <em class="not-italic font-medium text-text">reverse engineering</em>
          game achievement data on legacy platforms, and various experiments that never quite leave the prototype stage.
        </p>
        <a href="https://play.davidluky.com" target="_blank" rel="noopener noreferrer" class="mt-8 block max-w-[600px] no-underline">
          <ProjectImage project={roomWebProject} />
        </a>
      </div>

      <div class="grid grid-cols-2 gap-6 shrink-0 max-md:w-full max-sm:gap-4 md:w-[320px]">
        <a href="/projects" class="rounded-xl bg-[#0f0f0e] p-6 no-underline transition-colors hover:bg-[#141413]">
          <div class="text-4xl font-light tracking-tight text-text mb-2">{projects.length}</div>
          <div data-i18n="stat_projects" class="text-[12px] font-medium uppercase tracking-wider text-text-3">Projects</div>
        </a>
        <a href="https://play.davidluky.com" target="_blank" rel="noopener noreferrer" class="rounded-xl bg-[#0f0f0e] p-6 no-underline transition-colors hover:bg-[#141413]">
          <div class="text-4xl font-light tracking-tight text-text mb-2">{stats.theRoomGames}</div>
          <div data-i18n="stat_games_room" class="text-[12px] font-medium uppercase tracking-wider text-accent/80">Games in The Room</div>
        </a>
        <a href="/about" class="rounded-xl bg-[#0f0f0e] p-6 no-underline transition-colors hover:bg-[#141413]">
          <div class="text-4xl font-light tracking-tight text-text mb-2">{stats.yearsCoding}</div>
          <div data-i18n="stat_coding" class="text-[12px] font-medium uppercase tracking-wider text-text-3">Years Coding</div>
        </a>
        <details class="live-sites-tile relative rounded-xl bg-[#0f0f0e] p-6 transition-colors hover:bg-[#141413]">
          <summary class="stat-tile-summary cursor-pointer">
            <div class="text-4xl font-light tracking-tight text-text mb-2">{liveProjects.length}</div>
            <div data-i18n="stat_sites" class="text-[12px] font-medium uppercase tracking-wider text-text-3">Live Sites</div>
          </summary>
          <div id="live-sites-tooltip" class="live-sites-tooltip">
            {liveProjects.map(p => (
              <a href={p.liveUrl!} target="_blank" rel="noopener noreferrer" class="live-sites-link">
                <span class="live-sites-name">{p.name}</span>
                <span class="live-sites-url">{p.liveUrl!.replace("https://", "")}</span>
              </a>
            ))}
          </div>
        </details>
        <details class="achievements-tile relative rounded-xl bg-[#0f0f0e] p-6 transition-colors hover:bg-[#141413]">
          <summary class="stat-tile-summary cursor-pointer">
            <div class="text-4xl font-light tracking-tight text-text mb-2">{stats.theRoomAchievements}</div>
            <div data-i18n="stat_achievements" class="text-[12px] font-medium uppercase tracking-wider text-text-3">Achievements</div>
          </summary>
          <div id="achievements-tooltip" class="achievements-tooltip" data-i18n="stat_achievements_tip">The real achievements are the traumas we acquired along the way!</div>
        </details>
        <button id="lang-toggle" class="rounded-xl bg-[#0f0f0e] p-6 text-left cursor-pointer transition-colors hover:bg-[#141413] group">
          <div class="text-4xl font-light tracking-tight text-text mb-2">2</div>
          <div data-i18n="stat_lang" class="text-[12px] font-medium uppercase tracking-wider text-text-3 mb-2">Languages</div>
          <div class="flex gap-1.5 text-[11px] font-semibold">
            <span id="lang-en" class="rounded px-1.5 py-0.5 bg-accent/20 text-accent transition-colors">EN</span>
            <span id="lang-pt" class="rounded px-1.5 py-0.5 bg-transparent text-text-3 transition-colors">PT</span>
          </div>
        </button>
      </div>
    </div>
  </section>

  <section id="presence" class="mx-auto max-w-[1280px] px-12 pb-[88px] max-md:px-6 max-md:pb-16">
    <div class="mb-7 flex items-end justify-between gap-6 max-sm:flex-col max-sm:items-start">
      <div>
        <div data-i18n="presence_label" class="mb-4 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
          Online Presence
        </div>
        <h2 data-i18n="presence_heading" class="max-w-[620px] text-[30px] font-light leading-snug tracking-tight max-sm:text-[22px]">
          One hub for code, projects, writing, and public profiles.
        </h2>
      </div>
      <a href="/projects" data-i18n="presence_projects" class="text-sm font-medium text-accent no-underline transition-colors hover:text-text">
        View projects
      </a>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {socialProfiles.map((profile) => (
        <a
          href={profile.url}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-lg border border-border bg-bg-card p-5 no-underline transition-colors hover:border-accent/40"
        >
          <div class="mb-3 flex items-center justify-between gap-3">
            <span class="text-[13px] font-medium text-text">{profile.platform}</span>
            <span class="font-mono text-[11px] uppercase tracking-wider text-accent/80">{profile.kind}</span>
          </div>
          <div class="font-mono text-[12px] text-text-3">{profile.handle}</div>
          <p class="mt-4 text-[13px] leading-relaxed text-text-2" data-social-role={profile.platform}>
            {profile.role}
          </p>
        </a>
      ))}
    </div>
  </section>

  <Footer />
</Base>

<script is:inline define:vars={{ roomGames: stats.theRoomGames, roomAchievements: stats.theRoomAchievements }}>
  window.__stats = { roomGames, roomAchievements };
</script>
<script>
  import { applyI18n, setLanguage } from '../i18n/shared';
  import { socialProfiles } from '../data/socials';

  const pageStrings = {
    en: {
      hero_title: 'Developer. Gamer.<br>Builder of things.',
      hero_subtitle: 'Portfolio hub for the projects, games, tools, writing, and public profiles I keep shaping.',
      hero_cta: 'Continue reading',
      intro_label: 'Introduction',
      intro_heading: 'Most of what I build starts as something I want to use myself.',
      intro_p1: `<a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a> is a multiplayer RPG platform - ${window.__stats.roomGames} games, achievements, economy, tournaments. It started as a C++ desktop application and has since expanded to a <em class="not-italic font-medium text-text">full web client</em> built with React, TypeScript, and Firebase.`,
      intro_p2: 'I also build smaller things when a problem catches my attention: a <em class="not-italic font-medium text-text">WhatsApp bot</em> for automating gym check-ins, a tool for <em class="not-italic font-medium text-text">reverse engineering</em> game achievement data on legacy platforms, and various experiments that never quite leave the prototype stage.',
      stat_projects: 'Projects',
      stat_games_room: 'Games in The Room',
      stat_coding: 'Years Coding',
      stat_sites: 'Live Sites',
      stat_achievements: 'Achievements',
      stat_achievements_tip: 'The real achievements are the traumas we acquired along the way!',
      stat_lang: 'Languages',
      presence_label: 'Online Presence',
      presence_heading: 'One hub for code, projects, writing, and public profiles.',
      presence_projects: 'View projects',
    },
    pt: {
      hero_title: 'Desenvolvedor. Gamer.<br>Construtor de coisas.',
      hero_subtitle: 'Hub de portfólio para os projetos, jogos, ferramentas, escrita e perfis públicos que continuo moldando.',
      hero_cta: 'Continue lendo',
      intro_label: 'Introdução',
      intro_heading: 'A maioria do que eu construo começa como algo que eu mesmo quero usar.',
      intro_p1: `<a href="https://play.davidluky.com" class="border-b border-accent/30 font-medium text-text no-underline transition-colors hover:border-accent">The Room</a> é uma plataforma RPG multiplayer - ${window.__stats.roomGames} jogos, conquistas, economia e torneios. Começou como um aplicativo desktop em C++ e desde então se expandiu para um <em class="not-italic font-medium text-text">cliente web completo</em> feito com React, TypeScript e Firebase.`,
      intro_p2: 'Também construo coisas menores quando um problema chama minha atenção: um <em class="not-italic font-medium text-text">bot de WhatsApp</em> para automatizar check-ins na academia, uma ferramenta para <em class="not-italic font-medium text-text">engenharia reversa</em> de dados de conquistas em plataformas legadas, e vários experimentos que nunca saem da fase de protótipo.',
      stat_projects: 'Projetos',
      stat_games_room: 'Jogos em The Room',
      stat_coding: 'Anos Programando',
      stat_sites: 'Sites Online',
      stat_achievements: 'Conquistas',
      stat_achievements_tip: 'As verdadeiras conquistas são os traumas que adquirimos pelo caminho!',
      stat_lang: 'Idiomas',
      presence_label: 'Presença Online',
      presence_heading: 'Um hub para código, projetos, escrita e perfis públicos.',
      presence_projects: 'Ver projetos',
    },
  };

  function updateHeroAndPills(lang: string) {
    const s = pageStrings[lang as keyof typeof pageStrings];
    const heroH1 = document.querySelector('section.text-center h1');
    const heroP = document.querySelector('section.text-center p');
    const heroCta = document.querySelector('section.text-center a');
    if (heroH1) heroH1.innerHTML = s.hero_title;
    if (heroP) heroP.textContent = s.hero_subtitle;
    if (heroCta) {
      heroCta.innerHTML = s.hero_cta + ' <span class="text-lg">&darr;</span>';
    }

    const enPill = document.getElementById('lang-en');
    const ptPill = document.getElementById('lang-pt');
    if (enPill && ptPill) {
      enPill.className = lang === 'en'
        ? 'rounded px-1.5 py-0.5 bg-accent/20 text-accent transition-colors'
        : 'rounded px-1.5 py-0.5 bg-transparent text-text-3 transition-colors';
      ptPill.className = lang === 'pt'
        ? 'rounded px-1.5 py-0.5 bg-accent/20 text-accent transition-colors'
        : 'rounded px-1.5 py-0.5 bg-transparent text-text-3 transition-colors';
    }

    document.querySelectorAll('[data-social-role]').forEach((el) => {
      const profile = socialProfiles.find((item) => item.platform === el.getAttribute('data-social-role'));
      if (profile) el.textContent = lang === 'pt' ? profile.rolePt : profile.role;
    });

    document.querySelectorAll<HTMLImageElement>('[data-project-image-alt]').forEach((el) => {
      el.alt = lang === 'pt'
        ? el.dataset.altPt || el.alt
        : el.dataset.altEn || el.alt;
    });
  }

  let lang = applyI18n(pageStrings);
  updateHeroAndPills(lang);

  document.getElementById('lang-toggle')?.addEventListener('click', () => {
    lang = lang === 'en' ? 'pt' : 'en';
    setLanguage(lang);
    applyI18n(pageStrings);
    updateHeroAndPills(lang);
  });
</script>
