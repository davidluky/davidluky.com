---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const bosses = [
  { id: "chill_penguin",      name: "Chill Penguin",      nameJp: "アイシー・ペンギーゴ" },
  { id: "storm_eagle",        name: "Storm Eagle",        nameJp: "ストーム・イーグリード" },
  { id: "flame_mammoth",      name: "Flame Mammoth",      nameJp: "バーニン・ナウマンダー" },
  { id: "spark_mandrill",     name: "Spark Mandrill",     nameJp: "スパーク・マンドリラー" },
  { id: "armored_armadillo",  name: "Armored Armadillo",  nameJp: "アルマージ" },
  { id: "launch_octopus",     name: "Launch Octopus",     nameJp: "ランチャーン・オクトパルド" },
  { id: "boomer_kuwanger",    name: "Boomer Kuwanger",    nameJp: "ブーメル・クワンガー" },
  { id: "sting_chameleon",    name: "Sting Chameleon",    nameJp: "スティング・カメリーオ" },
  { id: "magma_dragoon",      name: "Magma Dragoon",      nameJp: "マグマード・ドラグーン" },
  { id: "vile",               name: "Vile",               nameJp: "VAVA" },
];

const animations = ["idle", "intro", "charge", "shoot", "slide", "jump", "stunned", "dying"];
---

<Base title="MMX Boss Animations — David Luky" description="Data-driven boss animation preview for the Mega Man X engine project.">
  <Header />

  <section class="mx-auto max-w-[1280px] px-12 pt-36 pb-12 max-md:px-6 max-md:pt-20">
    <div data-i18n="mmx_label" class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
      Mega Man X Engine
    </div>
    <h1 data-i18n="mmx_title" class="mb-4 max-w-[620px] text-[42px] font-light leading-tight tracking-tight max-md:text-3xl">
      Boss Animations
    </h1>
    <p data-i18n="mmx_subtitle" class="max-w-[600px] text-[17px] leading-relaxed text-text-2">
      Data-driven animation catalog for 10 bosses. Each animation is defined in JSON and loaded at runtime — no hardcoded frame data in C++.
    </p>
    <div class="mt-6 flex flex-wrap gap-3 text-[12px]">
      <span class="rounded-lg border border-border bg-bg-card px-3 py-1.5 text-text-2">C++ / raylib</span>
      <span class="rounded-lg border border-border bg-bg-card px-3 py-1.5 text-text-2">JSON-driven</span>
      <span class="rounded-lg border border-border bg-bg-card px-3 py-1.5 text-text-2">10 Bosses</span>
      <span class="rounded-lg border border-border bg-bg-card px-3 py-1.5 text-text-2">8 Animations Each</span>
    </div>
  </section>

  {bosses.map((boss) => (
    <section class="mx-auto max-w-[1280px] px-12 pb-16 max-md:px-6" id={boss.id}>
      <div class="rounded-xl border border-border bg-bg-card p-7 max-sm:p-4">
        <div class="mb-6 flex items-center gap-4">
          <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-accent/15">
            <img
              src={`/mmx-boss-animations/${boss.id}_idle.gif`}
              alt={boss.name}
              class="h-9 w-9 object-contain"
              style="image-rendering: pixelated;"
            />
          </div>
          <div>
            <h2 class="text-[18px] font-medium">{boss.name}</h2>
            <span class="font-mono text-[12px] text-text-3">{boss.nameJp}</span>
          </div>
        </div>

        <div class="mb-5">
          <h3 class="mb-3 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
            Sprite Strip
          </h3>
          <div class="overflow-x-auto rounded-lg bg-[#050505] p-4">
            <img
              src={`/mmx-boss-animations/${boss.id}_strip.png`}
              alt={`${boss.name} — all frames`}
              class="h-20 max-w-none"
              style="image-rendering: pixelated;"
            />
          </div>
        </div>

        <h3 class="mb-3 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
          Animations
        </h3>
        <div class="grid grid-cols-4 gap-3 max-md:grid-cols-3 max-sm:grid-cols-2">
          {animations.map((anim) => (
            <div class="flex flex-col items-center rounded-lg bg-[#050505] p-4">
              <img
                src={`/mmx-boss-animations/${boss.id}_${anim}.gif`}
                alt={`${boss.name} — ${anim}`}
                class="mb-2 h-16 w-16 object-contain"
                style="image-rendering: pixelated;"
              />
              <span class="font-mono text-[11px] text-text-3">{anim}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="mx-auto max-w-[1280px] px-12 pb-8 max-md:px-6">
    <div class="flex flex-wrap gap-2">
      {bosses.map((boss) => (
        <a
          href={`#${boss.id}`}
          class="rounded-md border border-border px-3 py-1.5 text-[12px] text-text-2 no-underline transition-colors hover:border-accent hover:text-accent"
        >
          {boss.name}
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[1280px] px-12 pb-24 max-md:px-6">
    <p class="text-[13px] text-text-3">
      Part of the <a href="/projects" class="text-text-2 no-underline hover:text-accent transition-colors">Mega Man X Engine</a> project.
      Animations extracted from SNES sprite sheets and defined in per-boss JSON files at
      <code class="rounded bg-[#0f0f0e] px-1.5 py-0.5 font-mono text-[12px] text-accent/70">content/x1/characters/bosses/</code>.
    </p>
  </section>

  <Footer />
</Base>

<script>
  import { applyI18n } from '../i18n/shared';
  applyI18n({
    en: {
      mmx_label: 'Mega Man X Engine',
      mmx_title: 'Boss Animations',
      mmx_subtitle: 'Data-driven animation catalog for 10 bosses. Each animation is defined in JSON and loaded at runtime — no hardcoded frame data in C++.',
    },
    pt: {
      mmx_label: 'Engine Mega Man X',
      mmx_title: 'Animações dos Bosses',
      mmx_subtitle: 'Catálogo de animações data-driven para 10 bosses. Cada animação é definida em JSON e carregada em tempo de execução — sem dados de frames hardcoded em C++.',
    },
  });
</script>
