---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/projects";

const liveSites = projects.filter(p => p.link).length;
const desktopApps = projects.filter(p => p.tag === "Desktop App").length;
const langs = new Set(projects.flatMap(p => p.tech)).size;

const tagColors: Record<string, string> = {
  "Game Platform": "text-accent",
  "Web App": "text-[#66c0f4]",
  "Marketplace": "text-[#f0c040]",
  "Desktop App": "text-[#a78bfa]",
  "Bot": "text-[#34d399]",
  "AI Tooling": "text-[#f472b6]",
  "Reverse Engineering": "text-[#fb923c]",
  "Automation": "text-[#38bdf8]",
  "Website": "text-accent",
};
---

<Base title="Projects — David Luky" description="Everything I've built: multiplayer games, marketplaces, desktop apps, bots, AI tooling, and more.">
  <Header currentPath="/projects" />

  <section class="mx-auto max-w-[1280px] px-12 pt-36 pb-20 max-md:px-6 max-md:pt-24">
    <div data-i18n="p_label" class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
      Projects
    </div>
    <h1 data-i18n="p_title" class="mb-6 max-w-[620px] text-[42px] font-light leading-tight tracking-tight max-md:text-3xl">
      Things I've built
    </h1>
    <p data-i18n="p_subtitle" class="max-w-[560px] text-[17px] leading-relaxed text-text-2">
      Most of what I build starts as something I want to use myself. Here's the full collection — from multiplayer games to automation bots to reverse engineering tools.
    </p>
  </section>

  <!-- Stats -->
  <section class="mx-auto max-w-[1280px] px-12 pb-14 max-md:px-6">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{projects.length}</div>
        <div data-i18n="p_stat_projects" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Projects</div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{langs}</div>
        <div data-i18n="p_stat_tech" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Technologies</div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{liveSites}</div>
        <div data-i18n="p_stat_live" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Live Sites</div>
      </div>
      <div class="rounded-xl bg-[#0f0f0e] p-6">
        <div class="text-3xl font-light tracking-tight text-text mb-1">{desktopApps}</div>
        <div data-i18n="p_stat_desktop" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Desktop Apps</div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1280px] px-12 pb-24 max-md:px-6">
    <div class="space-y-0">
      {projects.map((project, i) => (
        <article class="py-10 border-b border-border/30 last:border-0">
          <div
            class={`mb-3 text-[11px] font-medium uppercase tracking-wider ${tagColors[project.tag] || "text-accent"}`}
            data-i18n-tag={`tag_${i}`}
          >
            {project.tag}
          </div>
          <div class="flex items-start justify-between gap-12 max-md:flex-col max-md:gap-4">
            <div class="max-w-[560px]">
              <h2 class="mb-3 text-xl font-medium">
                {project.link ? (
                  <a
                    href={project.link}
                    target={project.link.startsWith("http") ? "_blank" : undefined}
                    rel={project.link.startsWith("http") ? "noopener noreferrer" : undefined}
                    class="border-b border-accent/30 no-underline transition-colors hover:border-accent"
                  >
                    {project.name}
                  </a>
                ) : (
                  project.name
                )}
              </h2>
              <p class="text-[15px] leading-relaxed text-text-2" data-i18n-desc={`desc_${i}`}>
                {project.description}
              </p>
            </div>
            <div class="flex flex-wrap gap-2 shrink-0 md:max-w-[200px] md:justify-end">
              {project.tech.map((t) => (
                <span class="rounded bg-white/[0.04] px-2.5 py-1 font-mono text-[11px] text-text-3">
                  {t}
                </span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <Footer />
</Base>

<script>
  const strings: Record<string, Record<string, string>> = {
    en: {
      nav_projects: 'Projects', nav_gaming: 'Gaming', nav_about: 'About', nav_play: 'Play The Room',
      footer_projects: 'Projects', footer_all_projects: 'All Projects', footer_gaming: 'Gaming', footer_profiles: 'Profiles', footer_connect: 'Connect',
      p_label: 'Projects',
      p_title: 'Things I\'ve built',
      p_subtitle: 'Most of what I build starts as something I want to use myself. Here\'s the full collection — from multiplayer games to automation bots to reverse engineering tools.',
      p_stat_projects: 'Projects',
      p_stat_tech: 'Technologies',
      p_stat_live: 'Live Sites',
      p_stat_desktop: 'Desktop Apps',
    },
    pt: {
      nav_projects: 'Projetos', nav_gaming: 'Jogos', nav_about: 'Sobre', nav_play: 'Jogar The Room',
      footer_projects: 'Projetos', footer_all_projects: 'Todos os Projetos', footer_gaming: 'Jogos', footer_profiles: 'Perfis', footer_connect: 'Contato',
      p_label: 'Projetos',
      p_title: 'Coisas que construí',
      p_subtitle: 'A maioria do que eu construo começa como algo que eu mesmo quero usar. Aqui está a coleção completa — de jogos multiplayer a bots de automação e ferramentas de engenharia reversa.',
      p_stat_projects: 'Projetos',
      p_stat_tech: 'Tecnologias',
      p_stat_live: 'Sites Online',
      p_stat_desktop: 'Apps Desktop',
    },
  };

  // Project descriptions and tags from data attributes
  const projectsPt: Record<string, { desc: string; tag: string }> = {
    '0':  { tag: 'Plataforma de Jogos', desc: 'Plataforma social multiplayer com 13 jogos, um RPG por turnos completo (7 zonas, boss endgame), chat em tempo real, 239 conquistas, torneios, economia e painel admin. O cliente desktop C++ original que começou tudo.' },
    '1':  { tag: 'App Web', desc: 'Companion web completo em React para o The Room, compartilhando o mesmo backend Firebase. 40 rotas, 3 temas visuais (Terminal, Híbrido, Moderno), bilíngue (EN/PT-BR), pronto para PWA.' },
    '2':  { tag: 'Marketplace', desc: 'Marketplace para serviços de Tibia — hunts, quests, bestiário, PK. Sistema de reservas com chat, verificação de personagem via TibiaData API, avaliações, resolução de disputas e destaques.' },
    '3':  { tag: 'App Desktop', desc: 'App desktop que agrega bibliotecas de jogos de Steam, Xbox, Epic, GOG, PlayStation, Nintendo, Game Pass e mais em uma única visualização. Busca FTS5, deduplicação de jogos, tokens criptografados, 3 temas.' },
    '4':  { tag: 'Bot', desc: 'Bot de WhatsApp que rastreia treinos na academia via reações em grupo. Publica relatórios diários, semanais e mensais em PT-BR. Detecta membros automaticamente e reconcilia check-ins.' },
    '5':  { tag: 'App Desktop', desc: 'App desktop para exportar conversas do WhatsApp em HTML/PDF com suporte completo de mídia. Login por QR code, merge opcional de backup ZIP, saída estilizada com lightbox e reações.' },
    '6':  { tag: 'Ferramentas de IA', desc: 'Estação de trabalho pessoal de IA para rodar modelos open-weight localmente via Ollama com escalação inteligente para nuvem. CLI estilo Claude Code, servidores MCP customizados, biblioteca de skills, framework de benchmark e rastreamento de custos.' },
    '7':  { tag: 'Engenharia Reversa', desc: 'DLL proxy que intercepta xlive.dll para desbloquear conquistas do Games for Windows Live no BioShock 2 e outros títulos GFWL. Thread watcher que monitora um arquivo para disparar IDs de conquistas.' },
    '8':  { tag: 'App Web', desc: 'Plataforma de histórias familiares com timeline por década, upload de DOCX/PDF, extração automática de imagens, acesso de leitura protegido por senha e painel admin.' },
    '9':  { tag: 'Automação', desc: 'Sistema automatizado de preservação de coleções retro — 200 títulos de Xbox 360 (1,66 TB) e 1.199 jogos de Nintendo 3DS (347 GB) do archive.org. Downloads em lote, verificação de integridade ZIP, rastreamento de duplicatas.' },
    '10': { tag: 'Bot', desc: 'Bot do Discord que multiplexa uma única assinatura do Midjourney entre vários usuários. Retransmite prompts /imagine e retorna imagens geradas em um canal compartilhado.' },
    '11': { tag: 'Website', desc: 'Este site. Hub pessoal para projetos, perfis de jogos e bio. Site estático com morph blackletter, alternância bilíngue e zero JS além da animação de scroll.' },
  };

  const lang = localStorage.getItem('dl-lang') || 'en';
  const s = strings[lang];
  if (s) {
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const key = el.getAttribute('data-i18n')!;
      if (key in s) el.innerHTML = s[key];
    });
  }

  if (lang === 'pt') {
    document.querySelectorAll('[data-i18n-tag]').forEach(el => {
      const idx = el.getAttribute('data-i18n-tag')!.replace('tag_', '');
      if (idx in projectsPt) el.textContent = projectsPt[idx].tag;
    });
    document.querySelectorAll('[data-i18n-desc]').forEach(el => {
      const idx = el.getAttribute('data-i18n-desc')!.replace('desc_', '');
      if (idx in projectsPt) el.textContent = projectsPt[idx].desc;
    });
  }
</script>
