---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ProjectImage from "../components/ProjectImage.astro";
import type { ProjectStatus } from "../data/projects";
import {
  featuredProjects,
  getProjectStatus,
  getProjectTag,
  getProjectVisibility,
  liveProjects,
  projects,
  projectStatuses,
  projectTags,
  projectVisibilities,
} from "../data/projects";

const activeProjects = projects.filter((project) => project.status !== "archived").length;
const desktopApps = projects.filter((project) => project.tag === "desktop-app").length;
const technologies = new Set(projects.flatMap((project) => project.tech)).size;
const remainingProjects = projects.filter((project) => !project.featured);
const statusProjectGroups = Object.entries(projectStatuses)
  .map(([status, statusMeta]) => ({
    status: status as ProjectStatus,
    statusMeta,
    projects: remainingProjects.filter((project) => project.status === status),
  }))
  .filter((group) => group.projects.length > 0);
const projectsStructuredData = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "David Luky Projects",
  itemListElement: liveProjects.map((project, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "SoftwareApplication",
      name: project.name,
      description: project.description,
      url: project.liveUrl,
      applicationCategory: getProjectTag(project).label,
      programmingLanguage: project.tech,
      ...(project.repoUrl ? { codeRepository: project.repoUrl } : {}),
    },
  })),
};

const externalTarget = (url: string) => url.startsWith("http") ? "_blank" : undefined;
const externalRel = (url: string) => url.startsWith("http") ? "noopener noreferrer" : undefined;
const searchableText = (project: (typeof projects)[number]) => [
  project.name,
  project.description,
  project.descriptionPt,
  project.tech.join(" "),
  getProjectTag(project).label,
  getProjectStatus(project).label,
  getProjectVisibility(project).label,
].join(" ").toLowerCase();
---

<Base title="Projects — David Luky" description="A curated portfolio of David Luky's games, web apps, automation tools, AI tooling, and internal systems." structuredData={projectsStructuredData}>
  <Header currentPath="/projects" />

  <section class="mx-auto max-w-[1280px] px-12 pt-36 pb-16 max-md:px-6 max-md:pt-20">
    <div data-i18n="p_label" class="mb-7 text-[11px] font-semibold uppercase tracking-[2.5px] text-accent">
      Projects
    </div>
    <h1 data-i18n="p_title" class="mb-6 max-w-[680px] text-[42px] font-light leading-tight tracking-tight max-md:text-3xl">
      Things I've built
    </h1>
    <p data-i18n="p_subtitle" class="max-w-[650px] text-[17px] leading-relaxed text-text-2">
      A curated map of the systems, games, utilities, and experiments I keep shaping: live products first, then the useful internal machinery behind them.
    </p>
  </section>

  <section class="mx-auto max-w-[1280px] px-12 pb-16 max-md:px-6">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
      <div class="rounded-lg bg-[#0f0f0e] p-6">
        <div class="mb-1 text-3xl font-light tracking-tight text-text">{projects.length}</div>
        <div data-i18n="p_stat_total" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Total Projects</div>
      </div>
      <div class="rounded-lg bg-[#0f0f0e] p-6">
        <div class="mb-1 text-3xl font-light tracking-tight text-text">{activeProjects}</div>
        <div data-i18n="p_stat_active" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Active / Maintained</div>
      </div>
      <div class="rounded-lg bg-[#0f0f0e] p-6">
        <div class="mb-1 text-3xl font-light tracking-tight text-text">{liveProjects.length}</div>
        <div data-i18n="p_stat_live" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Live Sites</div>
      </div>
      <div class="rounded-lg bg-[#0f0f0e] p-6">
        <div class="mb-1 text-3xl font-light tracking-tight text-text">{technologies}</div>
        <div data-i18n="p_stat_tech" class="text-[11px] font-medium uppercase tracking-wider text-text-3">Technologies</div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-[1280px] px-12 pb-18 max-md:px-6">
    <div class="mb-7 flex items-end justify-between gap-6 max-sm:flex-col max-sm:items-start">
      <div>
        <h2 data-i18n="p_featured_title" class="mb-2 text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
          Featured
        </h2>
        <p data-i18n="p_featured_desc" class="max-w-[560px] text-[14px] leading-relaxed text-text-2">
          The highest-signal projects: shipped products, active systems, and work that best represents how I build.
        </p>
      </div>
      <div class="font-mono text-[12px] text-text-3">{featuredProjects.length} / {projects.length}</div>
    </div>

    <div class="grid gap-4 lg:grid-cols-2">
      {featuredProjects.map((project) => {
        const tag = getProjectTag(project);
        const status = getProjectStatus(project);
        const visibility = getProjectVisibility(project);
        return (
          <article
            class="rounded-lg border border-border bg-bg-card p-6"
            data-project-card
            data-project-featured="true"
            data-project-search={searchableText(project)}
            data-project-tag-value={project.tag}
            data-project-status-value={project.status}
            data-project-visibility-value={project.visibility}
          >
            <ProjectImage project={project} class="mb-5" />

            <div class="mb-4 flex flex-wrap items-center gap-2">
              <span class={`text-[11px] font-medium uppercase tracking-wider ${tag.colorClass}`} data-project-tag={project.id}>
                {tag.label}
              </span>
              <span class="text-border">/</span>
              <span class="text-[11px] font-medium uppercase tracking-wider text-text-3" data-project-status={project.id}>
                {status.label}
              </span>
              <span class="text-border">/</span>
              <span class="text-[11px] font-medium uppercase tracking-wider text-text-3" data-project-visibility={project.id}>
                {visibility.label}
              </span>
            </div>

            <div class="mb-3 flex items-start justify-between gap-5">
              <h3 class="text-xl font-medium leading-snug">{project.name}</h3>
              <span class="shrink-0 font-mono text-[12px] text-text-3">{project.year}</span>
            </div>

            <p class="mb-5 text-[15px] leading-relaxed text-text-2" data-project-desc={project.id}>
              {project.description}
            </p>

            {project.metrics && (
              <div class="mb-5 flex flex-wrap gap-2">
                {project.metrics.map((metric, metricIndex) => (
                  <span
                    class="rounded bg-white/[0.04] px-2.5 py-1 font-mono text-[11px] text-text-3"
                    data-project-metric={`${project.id}:${metricIndex}`}
                  >
                    {metric}
                  </span>
                ))}
              </div>
            )}

            <div class="flex flex-wrap items-center justify-between gap-4">
              <div class="flex flex-wrap gap-2">
                {project.tech.map((tech) => (
                  <span class="rounded bg-white/[0.04] px-2.5 py-1 font-mono text-[11px] text-text-3">
                    {tech}
                  </span>
                ))}
              </div>
              <div class="flex shrink-0 gap-3">
                {project.liveUrl && (
                  <a
                    href={project.liveUrl}
                    target={externalTarget(project.liveUrl)}
                    rel={externalRel(project.liveUrl)}
                    data-i18n="p_live"
                    class="text-sm font-medium text-accent no-underline transition-colors hover:text-text"
                  >
                    Live
                  </a>
                )}
                {project.repoUrl && (
                  <a
                    href={project.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    data-i18n="p_source"
                    class="text-sm font-medium text-text-2 no-underline transition-colors hover:text-text"
                  >
                    Source
                  </a>
                )}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="mx-auto max-w-[1280px] px-12 pb-16 max-md:px-6">
    <div class="rounded-lg border border-border bg-bg-card p-5">
      <div class="mb-4 flex items-end justify-between gap-4 max-md:flex-col max-md:items-start">
        <div>
          <h2 data-i18n="p_filter_title" class="text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
            Find a Project
          </h2>
          <p data-i18n="p_filter_desc" class="mt-2 text-[13px] leading-relaxed text-text-2">
            Search by name, technology, status, project type, or public/private visibility.
          </p>
        </div>
        <button id="project-filter-clear" data-i18n="p_filter_clear" class="text-sm font-medium text-accent transition-colors hover:text-text">
          Clear filters
        </button>
      </div>

      <div class="grid gap-3 md:grid-cols-[1.4fr_1fr_1fr_1fr]">
        <label class="block">
          <span data-i18n="p_filter_search" class="mb-2 block font-mono text-[11px] uppercase tracking-wider text-text-3">Search</span>
          <input
            id="project-search"
            data-i18n-placeholder="p_filter_search_placeholder"
            type="search"
            placeholder="Try Firebase, AI, games, automation..."
            class="w-full rounded-md border border-border bg-[#0f0f0e] px-3 py-2.5 text-sm text-text outline-none transition-colors placeholder:text-text-3 focus:border-accent"
          />
        </label>
        <label class="block">
          <span data-i18n="p_filter_type" class="mb-2 block font-mono text-[11px] uppercase tracking-wider text-text-3">Type</span>
          <select id="project-tag-filter" class="w-full rounded-md border border-border bg-[#0f0f0e] px-3 py-2.5 text-sm text-text outline-none transition-colors focus:border-accent">
            <option value="" data-i18n="p_filter_all_types">All types</option>
            {Object.entries(projectTags).map(([value, tag]) => (
              <option value={value}>{tag.label}</option>
            ))}
          </select>
        </label>
        <label class="block">
          <span data-i18n="p_filter_status" class="mb-2 block font-mono text-[11px] uppercase tracking-wider text-text-3">Status</span>
          <select id="project-status-filter" class="w-full rounded-md border border-border bg-[#0f0f0e] px-3 py-2.5 text-sm text-text outline-none transition-colors focus:border-accent">
            <option value="" data-i18n="p_filter_all_statuses">All statuses</option>
            {Object.entries(projectStatuses).map(([value, status]) => (
              <option value={value}>{status.label}</option>
            ))}
          </select>
        </label>
        <label class="block">
          <span data-i18n="p_filter_visibility" class="mb-2 block font-mono text-[11px] uppercase tracking-wider text-text-3">Visibility</span>
          <select id="project-visibility-filter" class="w-full rounded-md border border-border bg-[#0f0f0e] px-3 py-2.5 text-sm text-text outline-none transition-colors focus:border-accent">
            <option value="" data-i18n="p_filter_all_visibility">All visibility</option>
            {Object.entries(projectVisibilities).map(([value, visibility]) => (
              <option value={value}>{visibility.label}</option>
            ))}
          </select>
        </label>
      </div>

      <p id="project-filter-count" class="mt-4 font-mono text-[12px] text-text-3" aria-live="polite"></p>
      <p id="project-filter-empty" data-i18n="p_filter_empty" class="mt-4 hidden text-sm text-text-2">
        No projects match these filters.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-[1280px] px-12 pb-24 max-md:px-6">
    <div class="mb-5 flex items-end justify-between gap-4">
      <h2 data-i18n="p_all_title" class="text-[11px] font-semibold uppercase tracking-[2.5px] text-text-3">
        By Status
      </h2>
      <span data-i18n="p_desktop_note" class="text-[12px] text-text-3">{desktopApps} desktop apps in the mix</span>
    </div>

    <div class="space-y-8">
      {statusProjectGroups.map(({ status, statusMeta, projects: groupProjects }) => (
        <div class="border-t border-border/40 pt-6" data-project-group>
          <div class="mb-3 flex items-baseline justify-between gap-4">
            <h3
              class="text-[13px] font-semibold uppercase tracking-[2px] text-text"
              data-project-group-label={status}
            >
              {statusMeta.label}
            </h3>
            <span class="font-mono text-[12px] text-text-3">{groupProjects.length}</span>
          </div>

          <div class="divide-y divide-border/30">
            {groupProjects.map((project) => {
              const tag = getProjectTag(project);
              const visibility = getProjectVisibility(project);
              return (
                <article
                  class="grid gap-4 py-5 md:grid-cols-[152px_minmax(0,1fr)] md:items-center lg:grid-cols-[152px_minmax(0,0.95fr)_minmax(0,1.15fr)_minmax(0,0.85fr)_auto]"
                  data-project-card
                  data-project-featured="false"
                  data-project-search={searchableText(project)}
                  data-project-tag-value={project.tag}
                  data-project-status-value={project.status}
                  data-project-visibility-value={project.visibility}
                >
                  <ProjectImage project={project} compact class="md:row-span-3 lg:row-span-1" />

                  <div class="min-w-0">
                    <div class="mb-2 flex flex-wrap items-center gap-2">
                      <span class={`text-[11px] font-medium uppercase tracking-wider ${tag.colorClass}`} data-project-tag={project.id}>
                        {tag.label}
                      </span>
                      <span class="text-border">/</span>
                      <span class="font-mono text-[12px] text-text-3">{project.year}</span>
                      <span class="text-border">/</span>
                      <span class="text-[11px] font-medium uppercase tracking-wider text-text-3" data-project-visibility={project.id}>
                        {visibility.label}
                      </span>
                    </div>
                    <h4 class="truncate text-[17px] font-medium leading-snug">{project.name}</h4>
                  </div>

                  <p class="min-w-0 truncate text-[14px] leading-relaxed text-text-2" data-project-desc={project.id}>
                    {project.description}
                  </p>

                  <div class="flex min-w-0 flex-wrap gap-2">
                    {project.tech.map((tech) => (
                      <span class="rounded bg-white/[0.04] px-2.5 py-1 font-mono text-[11px] text-text-3">
                        {tech}
                      </span>
                    ))}
                  </div>

                  <div class="flex shrink-0 gap-3 md:justify-end">
                    {project.liveUrl && (
                      <a
                        href={project.liveUrl}
                        target={externalTarget(project.liveUrl)}
                        rel={externalRel(project.liveUrl)}
                        data-i18n="p_live"
                        class="text-sm font-medium text-accent no-underline transition-colors hover:text-text"
                      >
                        Live
                      </a>
                    )}
                    {project.repoUrl && (
                      <a
                        href={project.repoUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-i18n="p_source"
                        class="text-sm font-medium text-text-2 no-underline transition-colors hover:text-text"
                      >
                        Source
                      </a>
                    )}
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </section>

  <Footer />
</Base>

<script>
  import { applyI18n } from '../i18n/shared';
  import { projectStatuses, projectTags, projectVisibilities, projects } from '../data/projects';

  const desktopApps = projects.filter((project) => project.tag === 'desktop-app').length;

  const lang = applyI18n({
    en: {
      p_label: 'Projects',
      p_title: 'Things I\'ve built',
      p_subtitle: 'A curated map of the systems, games, utilities, and experiments I keep shaping: live products first, then the useful internal machinery behind them.',
      p_stat_total: 'Total Projects',
      p_stat_active: 'Active / Maintained',
      p_stat_live: 'Live Sites',
      p_stat_tech: 'Technologies',
      p_filter_title: 'Find a Project',
      p_filter_desc: 'Search by name, technology, status, project type, or public/private visibility.',
      p_filter_clear: 'Clear filters',
      p_filter_search: 'Search',
      p_filter_search_placeholder: 'Try Firebase, AI, games, automation...',
      p_filter_type: 'Type',
      p_filter_all_types: 'All types',
      p_filter_status: 'Status',
      p_filter_all_statuses: 'All statuses',
      p_filter_visibility: 'Visibility',
      p_filter_all_visibility: 'All visibility',
      p_filter_empty: 'No projects match these filters.',
      p_featured_title: 'Featured',
      p_featured_desc: 'The highest-signal projects: shipped products, active systems, and work that best represents how I build.',
      p_all_title: 'By Status',
      p_desktop_note: `${desktopApps} desktop apps in the mix`,
      p_live: 'Live',
      p_source: 'Source',
    },
    pt: {
      p_label: 'Projetos',
      p_title: 'Coisas que construí',
      p_subtitle: 'Um mapa curado dos sistemas, jogos, utilitários e experimentos que continuo moldando: produtos online primeiro, depois a maquinaria interna útil por trás deles.',
      p_stat_total: 'Projetos no Total',
      p_stat_active: 'Ativos / Mantidos',
      p_stat_live: 'Sites Online',
      p_stat_tech: 'Tecnologias',
      p_filter_title: 'Encontrar Projeto',
      p_filter_desc: 'Busque por nome, tecnologia, status, tipo de projeto ou visibilidade pública/privada.',
      p_filter_clear: 'Limpar filtros',
      p_filter_search: 'Busca',
      p_filter_search_placeholder: 'Tente Firebase, IA, jogos, automação...',
      p_filter_type: 'Tipo',
      p_filter_all_types: 'Todos os tipos',
      p_filter_status: 'Status',
      p_filter_all_statuses: 'Todos os status',
      p_filter_visibility: 'Visibilidade',
      p_filter_all_visibility: 'Todas as visibilidades',
      p_filter_empty: 'Nenhum projeto combina com estes filtros.',
      p_featured_title: 'Destaques',
      p_featured_desc: 'Os projetos de maior sinal: produtos publicados, sistemas ativos e trabalhos que melhor representam como eu construo.',
      p_all_title: 'Por Status',
      p_desktop_note: `${desktopApps} apps desktop na mistura`,
      p_live: 'Online',
      p_source: 'Código',
    },
  });

  if (lang === 'pt') {
    document.querySelectorAll('[data-project-desc]').forEach((el) => {
      const project = projects.find((item) => item.id === el.getAttribute('data-project-desc'));
      if (project) el.textContent = project.descriptionPt;
    });

    document.querySelectorAll('[data-project-tag]').forEach((el) => {
      const project = projects.find((item) => item.id === el.getAttribute('data-project-tag'));
      if (project) el.textContent = projectTags[project.tag].labelPt;
    });

    document.querySelectorAll('[data-project-status]').forEach((el) => {
      const project = projects.find((item) => item.id === el.getAttribute('data-project-status'));
      if (project) el.textContent = projectStatuses[project.status].labelPt;
    });

    document.querySelectorAll('[data-project-visibility]').forEach((el) => {
      const project = projects.find((item) => item.id === el.getAttribute('data-project-visibility'));
      if (project) el.textContent = projectVisibilities[project.visibility].labelPt;
    });

    document.querySelectorAll('[data-project-group-label]').forEach((el) => {
      const status = el.getAttribute('data-project-group-label');
      if (status && status in projectStatuses) {
        el.textContent = projectStatuses[status as keyof typeof projectStatuses].labelPt;
      }
    });

    document.querySelectorAll('[data-project-metric]').forEach((el) => {
      const [projectId, metricIndex] = el.getAttribute('data-project-metric')!.split(':');
      const project = projects.find((item) => item.id === projectId);
      const translatedMetric = project?.metricsPt?.[Number(metricIndex)];
      if (translatedMetric) el.textContent = translatedMetric;
    });

    document.querySelectorAll<HTMLOptionElement>('#project-tag-filter option[value]').forEach((option) => {
      if (option.value && option.value in projectTags) option.textContent = projectTags[option.value as keyof typeof projectTags].labelPt;
    });
    document.querySelectorAll<HTMLOptionElement>('#project-status-filter option[value]').forEach((option) => {
      if (option.value && option.value in projectStatuses) option.textContent = projectStatuses[option.value as keyof typeof projectStatuses].labelPt;
    });
    document.querySelectorAll<HTMLOptionElement>('#project-visibility-filter option[value]').forEach((option) => {
      if (option.value && option.value in projectVisibilities) option.textContent = projectVisibilities[option.value as keyof typeof projectVisibilities].labelPt;
    });
  }

  document.querySelectorAll<HTMLImageElement>('[data-project-image-alt]').forEach((el) => {
    el.alt = lang === 'pt'
      ? el.dataset.altPt || el.alt
      : el.dataset.altEn || el.alt;
  });

  const search = document.getElementById('project-search') as HTMLInputElement | null;
  const tag = document.getElementById('project-tag-filter') as HTMLSelectElement | null;
  const status = document.getElementById('project-status-filter') as HTMLSelectElement | null;
  const visibility = document.getElementById('project-visibility-filter') as HTMLSelectElement | null;
  const clear = document.getElementById('project-filter-clear');
  const count = document.getElementById('project-filter-count');
  const empty = document.getElementById('project-filter-empty');
  const cards = [...document.querySelectorAll<HTMLElement>('[data-project-card]')];
  const groups = [...document.querySelectorAll<HTMLElement>('[data-project-group]')];

  function updateProjectFilters() {
    const query = search?.value.trim().toLowerCase() ?? '';
    const tagValue = tag?.value ?? '';
    const statusValue = status?.value ?? '';
    const visibilityValue = visibility?.value ?? '';
    let visibleProjects = 0;

    for (const card of cards) {
      const matches =
        (!query || (card.dataset.projectSearch ?? '').includes(query)) &&
        (!tagValue || card.dataset.projectTagValue === tagValue) &&
        (!statusValue || card.dataset.projectStatusValue === statusValue) &&
        (!visibilityValue || card.dataset.projectVisibilityValue === visibilityValue);

      card.hidden = !matches;
      if (matches) visibleProjects += 1;
    }

    for (const group of groups) {
      const hasVisibleProject = [...group.querySelectorAll<HTMLElement>('[data-project-card]')]
        .some((card) => !card.hidden);
      group.hidden = !hasVisibleProject;
    }

    if (count) {
      count.textContent = lang === 'pt'
        ? `${visibleProjects} de ${cards.length} projetos visíveis`
        : `${visibleProjects} of ${cards.length} projects visible`;
    }
    empty?.classList.toggle('hidden', visibleProjects !== 0);
  }

  [search, tag, status, visibility].forEach((control) => {
    control?.addEventListener('input', updateProjectFilters);
    control?.addEventListener('change', updateProjectFilters);
  });

  clear?.addEventListener('click', () => {
    if (search) search.value = '';
    if (tag) tag.value = '';
    if (status) status.value = '';
    if (visibility) visibility.value = '';
    updateProjectFilters();
  });

  document.querySelectorAll<HTMLElement>('[data-i18n-placeholder]').forEach((el) => {
    const key = el.dataset.i18nPlaceholder;
    if (key && key in (lang === 'pt' ? {
      p_filter_search_placeholder: 'Tente Firebase, IA, jogos, automação...',
    } : {
      p_filter_search_placeholder: 'Try Firebase, AI, games, automation...',
    })) {
      el.setAttribute('placeholder', lang === 'pt' ? 'Tente Firebase, IA, jogos, automação...' : 'Try Firebase, AI, games, automation...');
    }
  });

  updateProjectFilters();
</script>
